<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Property Line Tool - T3Lab"
       Width="680" Height="720"
       MinWidth="580" MinHeight="560"
       WindowStartupLocation="CenterScreen"
       ResizeMode="CanResizeWithGrip"
       ShowInTaskbar="True"
       Background="White"
       FontFamily="Inter"
       FontSize="12">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ── Primary button (blue, BatchOut style) ── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#083D56"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#062A3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#062A3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#546E7A"/>
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Secondary button (light gray) ── -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E6EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Success button (green) ── -->
        <Style x:Key="SuccessBtn" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E8449"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#546E7A"/>
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Input field (white, light border) ── -->
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#083D56"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── PasswordBox ── -->
        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- ── GroupBox ── -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ── Field label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ── Window control button ── -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Close button (red on hover) ── -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>    <!-- Custom title bar -->
            <RowDefinition Height="*"/>     <!-- Scrollable content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
            <RowDefinition Height="Auto"/>  <!-- Action buttons + copyright -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ TITLE BAR (T3Lab / BatchOut style) -->
        <Grid Grid.Row="0" Background="White" Height="64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- T3Lab Title + Subtitle -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#083D56" VerticalAlignment="Bottom" Margin="0,0,6,3"/>
                    <TextBlock Text="Property Line Tool" FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                </StackPanel>
                <Separator Height="1" Background="#546E7A" Margin="0,2,0,2"/>
                <TextBlock Text="Draw property boundaries from Lightbox RE API"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <!-- Window control buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Top" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">

                <!-- Minimize -->
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Minimize"
                        Click="btn_minimize_Click">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>

                <!-- Close -->
                <Button x:Name="btn_close_x"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close"
                        Click="btn_close_Click">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
            <StackPanel>

                <!-- ─── API KEY ─── -->
                <GroupBox Header=" API Configuration">
                    <StackPanel>
                        <TextBlock Text="Lightbox API Key" Style="{StaticResource FieldLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txt_api_key"
                                     Grid.Column="0"
                                     Style="{StaticResource InputField}"
                                     ToolTip="Enter your Lightbox RE API key. Get one at https://lightboxre.com"
                                     Margin="0,0,8,0"/>
                            <Button x:Name="btn_save_key"
                                    Grid.Column="1"
                                    Content="Save"
                                    Style="{StaticResource SecondaryBtn}"
                                    Click="btn_save_key_Click"/>
                        </Grid>
                        <TextBlock x:Name="txt_api_status"
                                   Text="No API key configured"
                                   Foreground="#D32F2F"
                                   FontSize="11"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- ─── ADDRESS SEARCH ─── -->
                <GroupBox Header=" Search Property by Address">
                    <StackPanel>
                        <TextBlock Text="US Property Address" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txt_address"
                                     Grid.Column="0"
                                     Style="{StaticResource InputField}"
                                     KeyDown="txt_address_KeyDown"
                                     ToolTip="e.g. 123 Main St, Los Angeles, CA 90001"
                                     Margin="0,0,8,0"/>
                            <Button x:Name="btn_search"
                                    Grid.Column="1"
                                    Content="Search"
                                    MinWidth="80"
                                    Style="{StaticResource PrimaryBtn}"
                                    Click="btn_search_Click"/>
                        </Grid>
                        <!-- Inline address validation warning -->
                        <TextBlock x:Name="txt_address_warning"
                                   Foreground="#E67E22" FontSize="11"
                                   Margin="0,4,0,4" TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                        <TextBlock Text="Examples: 350 Fifth Ave, New York NY | 1600 Pennsylvania Ave NW, Washington DC"
                                   Foreground="#7F8C8D" FontSize="10" FontStyle="Italic"/>
                    </StackPanel>
                </GroupBox>

                <!-- ─── SEARCH RESULTS ─── -->
                <GroupBox Header=" Search Results">
                    <StackPanel>
                        <Border x:Name="border_no_results"
                                Background="#F8F9FA" CornerRadius="4" Padding="16"
                                BorderBrush="#D0D0D0" BorderThickness="1"
                                Margin="0,0,0,8">
                            <TextBlock Text="Enter an address above and click Search to find parcels"
                                       Foreground="#7F8C8D" HorizontalAlignment="Center"
                                       FontStyle="Italic"/>
                        </Border>

                        <ListView x:Name="lv_parcels"
                                  Background="White"
                                  BorderBrush="#D0D0D0"
                                  BorderThickness="1"
                                  Foreground="#2C3E50"
                                  MaxHeight="200"
                                  Visibility="Collapsed"
                                  SelectionChanged="lv_parcels_SelectionChanged">
                            <ListView.Resources>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8F9FA"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#083D56"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.Resources>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Address" Width="280"
                                                    DisplayMemberBinding="{Binding display_address}"/>
                                    <GridViewColumn Header="Parcel ID" Width="140"
                                                    DisplayMemberBinding="{Binding parcel_id}"/>
                                    <GridViewColumn Header="Area (sqft)" Width="100"
                                                    DisplayMemberBinding="{Binding area_sqft}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </GroupBox>

                <!-- ─── SELECTED PARCEL DETAILS ─── -->
                <GroupBox x:Name="grp_parcel_details"
                          Header=" Selected Parcel Details"
                          Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left column -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Parcel ID (APN)" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_id" Foreground="#2C3E50" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_address" Foreground="#2C3E50" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="County" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_county" Foreground="#2C3E50" Margin="0,0,0,10"/>

                            <TextBlock Text="Zoning Code" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_zoning" Foreground="#E67E22" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Area" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_area" Foreground="#27AE60" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <TextBlock Text="Coordinates (Vertices)" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_vertices" Foreground="#7F8C8D" Margin="0,0,0,10"/>

                            <TextBlock Text="State" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_state" Foreground="#2C3E50" Margin="0,0,0,10"/>

                            <TextBlock Text="Flood Zone (FEMA)" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_flood" Foreground="#7F8C8D" Margin="0,0,0,10"/>
                        </StackPanel>

                        <!-- Full-width bottom: Legal + Land Use + Map button -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <TextBlock Text="Legal Description" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_legal"
                                       Foreground="#2C3E50" Margin="0,0,0,10"
                                       TextWrapping="Wrap" FontSize="11"/>

                            <TextBlock Text="Land Use" Style="{StaticResource FieldLabel}"/>
                            <TextBlock x:Name="txt_detail_land_use" Foreground="#7F8C8D" Margin="0,0,0,12"/>

                            <Button x:Name="btn_download_map"
                                    Content="🗺  Download Parcel Map (OpenStreetMap)"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource PrimaryBtn}"
                                    Click="btn_download_map_Click"
                                    ToolTip="Fetches OSM map tiles, overlays the parcel boundary in blue, and opens the PNG."/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ─── PROJECT DATA PREVIEW ─── -->
                <GroupBox x:Name="grp_project_data"
                          Header=" Project Data"
                          Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Auto-generated from parcel data."
                                   Foreground="#7F8C8D" FontSize="10" FontStyle="Italic"
                                   Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Border Background="#F8F9FA" CornerRadius="3" Padding="10"
                                BorderBrush="#D0D0D0" BorderThickness="1"
                                Margin="0,0,0,8">
                            <TextBlock x:Name="txt_project_data"
                                       Foreground="#2C3E50"
                                       FontFamily="Consolas, Courier New, monospace"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <Button x:Name="btn_copy_project_data"
                                Content="Copy to Clipboard"
                                HorizontalAlignment="Left"
                                Style="{StaticResource SecondaryBtn}"
                                Click="btn_copy_project_data_Click"/>
                    </StackPanel>
                </GroupBox>

                <!-- ─── SETBACK LINES (shown only when API returns setback data) ─── -->
                <GroupBox x:Name="grp_setback"
                          Header=" Setback Information"
                          Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Setback distances from parcel data (read-only):"
                                   Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="txt_setback_info"
                                   Foreground="#2C3E50" FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>

                <!-- ─── REVIT CREATION OPTIONS ─── -->
                <GroupBox Header=" Revit Creation Options">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Elevation (ft)" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txt_elevation" Text="0.0"
                                     Style="{StaticResource InputField}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Line Category" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cmb_line_type"
                                      Background="White"
                                      Foreground="#2C3E50"
                                      BorderBrush="#546E7A"
                                      Padding="6,5"
                                      ToolTip="Note: Revit API does not support direct PropertyLine creation. All options create Model/Detail lines; use Revit's Pick Lines to convert to native PropertyLine.">
                                <ComboBoxItem Content="Model Lines" IsSelected="True"/>
                                <ComboBoxItem Content="Detail Lines"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Origin" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cmb_origin"
                                      Background="White"
                                      Foreground="#2C3E50"
                                      BorderBrush="#546E7A"
                                      Padding="6,5">
                                <ComboBoxItem Content="Project Base Point" IsSelected="True"/>
                                <ComboBoxItem Content="Survey Point"/>
                                <ComboBoxItem Content="World Origin (0,0,0)"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════ STATUS BAR -->
        <Border Grid.Row="2" Background="#F8F9FA"
                BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                Padding="16,8">
            <DockPanel>
                <TextBlock x:Name="txt_status"
                           Text="Ready. Enter an address to begin."
                           Foreground="#7F8C8D"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Ellipse x:Name="dot_status"
                             Width="8" Height="8"
                             Fill="#546E7A"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"/>
                    <TextBlock x:Name="txt_status_label"
                               Text="Idle"
                               Foreground="#7F8C8D"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ ACTION BUTTONS -->
        <Border Grid.Row="3" Background="#F8F9FA"
                BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                Padding="16,12">
            <StackPanel>
                <DockPanel>
                    <Button x:Name="btn_cancel"
                            DockPanel.Dock="Right"
                            Content="Close"
                            MinWidth="90"
                            Style="{StaticResource SecondaryBtn}"
                            Click="btn_close_Click"/>
                    <Button x:Name="btn_create"
                            Content="Create Property Lines in Revit"
                            Style="{StaticResource SuccessBtn}"
                            IsEnabled="False"
                            Margin="0,0,10,0"
                            Click="btn_create_Click"/>
                </DockPanel>
                <!-- Copyright -->
                <TextBlock Text="© Copyright by T3Lab"
                           FontSize="11" Foreground="#3498DB"
                           HorizontalAlignment="Right"
                           Margin="0,8,14,0"
                           IsHitTestVisible="False"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
