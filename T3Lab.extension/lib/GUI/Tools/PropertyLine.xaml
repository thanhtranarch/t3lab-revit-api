<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Property Line Tool - T3Lab"
        Width="1000" Height="760"
        MinWidth="800" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="#F9FAFB"
        FontFamily="Inter"
        FontSize="12">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ── Primary button (blue, BatchOut/Kinetix style) ── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#083D56"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#062A3C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                    <Setter Property="Foreground" Value="#E5E7EB"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Secondary button (light gray) ── -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                    <Setter Property="BorderBrush" Value="#9CA3AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Input field (white, light border) ── -->
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#083D56"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Premium modern GroupBox card style ── -->
        <Style x:Key="PremiumCard" TargetType="GroupBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Card Header -->
                                <Border Grid.Row="0" 
                                        Background="White"
                                        Padding="16,12"
                                        BorderBrush="#F3F4F6"
                                        BorderThickness="0,0,0,1">
                                    <ContentPresenter ContentSource="Header"
                                                      RecognizeAccessKey="True"
                                                      TextBlock.FontSize="13"
                                                      TextBlock.FontWeight="Bold"
                                                      TextBlock.Foreground="#1F2937"/>
                                </Border>
                                
                                <!-- Card Content -->
                                <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Field label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- ── Window control button ── -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Close button (red on hover) ── -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>    <!-- Modern Title bar -->
            <RowDefinition Height="*"/>     <!-- 2-Column Content -->
            <RowDefinition Height="Auto"/>  <!-- Bottom Action + Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ MODERN TITLE BAR -->
        <Grid Grid.Row="0" Background="White" Height="64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- T3Lab Title + Subtitle Brand layout -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                <TextBlock Text="T3Lab" FontSize="16" FontWeight="Bold" Foreground="#083D56" VerticalAlignment="Center"/>
                <Border Width="1" Height="16" Background="#E5E7EB" Margin="12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Property Line Tool" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Window controls + Profile Icon -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                
                <!-- Profile circular icon from design image -->
                <Border Width="32" Height="32" CornerRadius="16" Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" 
                        VerticalAlignment="Center" Margin="0,0,16,0" ToolTip="User Profile">
                    <Grid>
                        <!-- Stylized modern human head outline -->
                        <Ellipse Width="10" Height="10" Fill="#9CA3AF" VerticalAlignment="Top" Margin="0,6,0,0"/>
                        <Path Data="M 6,24 A 10,10 0 0,1 26,24 Z" Fill="#9CA3AF" Stretch="Fill" VerticalAlignment="Bottom" Height="10" Margin="4,0,4,3"/>
                    </Grid>
                </Border>

                <!-- Minimize -->
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Minimize"
                        Click="btn_minimize_Click"
                        Margin="0,0,4,0">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#4B5563"/>
                </Button>

                <!-- Close -->
                <Button x:Name="btn_close_x"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close"
                        Click="btn_close_Click">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#4B5563">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
            
            <Border Height="1" VerticalAlignment="Bottom" Background="#E5E7EB"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ CONTENT (2-COLUMN) -->
        <Grid Grid.Row="1" Background="#F9FAFB">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/> <!-- Left column: API Config & Details -->
                <ColumnDefinition Width="*"/>   <!-- Right column: Search & Results -->
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN (Scrollable details and configuration) -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="24,20,12,20">
                <StackPanel>
                    
                    <!-- ─── API KEY CARD ─── -->
                    <GroupBox Header="API Configuration" Style="{StaticResource PremiumCard}">
                        <StackPanel>
                            <TextBlock Text="Lightbox API Key" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txt_api_key"
                                         Grid.Column="0"
                                         Style="{StaticResource InputField}"
                                         ToolTip="Enter your Lightbox RE API key."
                                         Margin="0,0,8,0"/>
                                <Button x:Name="btn_save_key"
                                        Grid.Column="1"
                                        Content="Save"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="btn_save_key_Click"/>
                            </Grid>
                            <TextBlock x:Name="txt_api_status"
                                       Text="No API key configured"
                                       Foreground="#D32F2F"
                                       FontSize="11"
                                       FontWeight="Medium"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ─── SELECTED PARCEL DETAILS CARD (Collapsed initially) ─── -->
                    <GroupBox x:Name="grp_parcel_details"
                              Header="Selected Parcel Details"
                              Style="{StaticResource PremiumCard}"
                              Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Parcel ID (APN)" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txt_detail_id" Foreground="#1F2937" FontSize="13" Margin="0,0,0,12" FontWeight="Medium"/>

                                <TextBlock Text="Address" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txt_detail_address" Foreground="#1F2937" FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="County" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="txt_detail_county" Foreground="#1F2937" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="State" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="txt_detail_state" Foreground="#1F2937" FontSize="13"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="1">
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Zoning Code" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="txt_detail_zoning" Foreground="#E67E22" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Area" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="txt_detail_area" Foreground="#27AE60" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Vertices" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="txt_detail_vertices" Foreground="#4B5563" FontSize="13"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Flood Zone (FEMA)" Style="{StaticResource FieldLabel}"/>
                                        <TextBlock x:Name="txt_detail_flood" Foreground="#4B5563" FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Land Use" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txt_detail_land_use" Foreground="#4B5563" FontSize="13" Margin="0,0,0,12"/>

                                <TextBlock Text="Legal Description" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="txt_detail_legal" Foreground="#4B5563" Margin="0,0,0,14" TextWrapping="Wrap" FontSize="11" LineHeight="15"/>
                            </StackPanel>

                            <Button x:Name="btn_download_map"
                                    Grid.Row="2"
                                    Content="🗺  Save Parcel Map PNG"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="btn_download_map_Click"
                                    ToolTip="Export parcel map view overlay as high-res PNG file."/>
                        </Grid>
                    </GroupBox>

                    <!-- ─── SETBACK LINES CARD (Collapsed initially) ─── -->
                    <GroupBox x:Name="grp_setback"
                              Header="Setback Information"
                              Style="{StaticResource PremiumCard}"
                              Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Setback distances from parcel data (read-only):"
                                       Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txt_setback_info"
                                       Foreground="#1F2937" FontSize="13" FontWeight="SemiBold"
                                       TextWrapping="Wrap" LineHeight="18"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ─── PROJECT DATA PREVIEW CARD (Collapsed initially) ─── -->
                    <GroupBox x:Name="grp_project_data"
                              Header="Project Data"
                              Style="{StaticResource PremiumCard}"
                              Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Auto-generated from parcel registry."
                                       Foreground="#9CA3AF" FontSize="10" FontStyle="Italic"
                                       Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <Border Background="#F9FAFB" CornerRadius="4" Padding="12"
                                    BorderBrush="#E5E7EB" BorderThickness="1"
                                    Margin="0,0,0,12">
                                <TextBlock x:Name="txt_project_data"
                                           Foreground="#374151"
                                           FontFamily="Consolas, Courier New, monospace"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           LineHeight="16"/>
                            </Border>
                            <Button x:Name="btn_copy_project_data"
                                    Content="Copy to Clipboard"
                                    HorizontalAlignment="Stretch"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="btn_copy_project_data_Click"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT COLUMN (Scrollable search, map, parcel lists, creation options) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="12,20,24,20">
                <StackPanel>
                    
                    <!-- ─── ADDRESS SEARCH CARD ─── -->
                    <GroupBox Header="Search Property by Address" Style="{StaticResource PremiumCard}">
                        <StackPanel>
                            <TextBlock Text="US Property Address" Style="{StaticResource FieldLabel}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txt_address"
                                         Grid.Column="0"
                                         Style="{StaticResource InputField}"
                                         KeyDown="txt_address_KeyDown"
                                         ToolTip="e.g. 123 Main St, Los Angeles, CA 90001"
                                         Margin="0,0,8,0"/>
                                <Button x:Name="btn_search"
                                        Grid.Column="1"
                                        Content="Search"
                                        Width="100"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="btn_search_Click"/>
                            </Grid>
                            
                            <!-- Inline address validation warning -->
                            <TextBlock x:Name="txt_address_warning"
                                       Foreground="#E67E22" FontSize="11"
                                       Margin="0,0,0,6" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                            <TextBlock Text="Example: 2255 Erwin Ah B., Ossana Mululerd, Carstore, CA 23062"
                                       Foreground="#9CA3AF" FontSize="11" FontStyle="Italic"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ─── SEARCH RESULTS CARD (MAP + RADIO BUTTONS) ─── -->
                    <GroupBox Header="Search Results" Style="{StaticResource PremiumCard}">
                        <Grid Height="300">
                            <Grid.ColumnDefinitions>
                                <Grid.ColumnDefinition Width="1.3*"/> <!-- Map view -->
                                <Grid.ColumnDefinition Width="1.7*"/> <!-- Address radio list -->
                            </Grid.ColumnDefinitions>

                            <!-- Column 0: Map Container -->
                            <Border Grid.Column="0" Background="#F3F4F6" CornerRadius="6" BorderBrush="#E5E7EB" BorderThickness="1" ClipToBounds="True" Margin="0,0,20,0">
                                <Grid>
                                    <!-- Beautiful Vector Road Line Placeholder -->
                                    <Canvas Opacity="0.3">
                                        <Path Stroke="#FFFFFF" StrokeThickness="16" Data="M -50,80 L 400,120 M 120,-50 L 160,400 M -20,200 L 350,80"/>
                                        <Path Stroke="#E5E7EB" StrokeThickness="8" Data="M -50,80 L 400,120 M 120,-50 L 160,400 M -20,200 L 350,80"/>
                                        <Path Stroke="#FFFFFF" StrokeThickness="10" Data="M 40,-50 Q 70,100 280,260"/>
                                        <Path Stroke="#E5E7EB" StrokeThickness="5" Data="M 40,-50 Q 70,100 280,260"/>
                                    </Canvas>
                                    
                                    <!-- Dynamic Loaded Map Image -->
                                    <Image x:Name="img_map_preview" Stretch="UniformToFill"/>
                                    
                                    <!-- Centered Location Pin Overlay -->
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="32" Height="32" Margin="0,0,0,14">
                                        <Ellipse Fill="#2563EB" Width="14" Height="14" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                                        <Ellipse Fill="White" Width="5" Height="5" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        <Path Fill="#2563EB" Data="M 6,10 L 12,6 L 12,9 Z" HorizontalAlignment="Center" VerticalAlignment="Bottom" Height="14" Width="12" Stretch="Fill" Margin="0,8,0,0"/>
                                    </Grid>
                                    
                                    <!-- Map Preview Watermark Label in bottom-left -->
                                    <Border Background="White" CornerRadius="3" Padding="8,4" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" BorderBrush="#E5E7EB" BorderThickness="1">
                                        <TextBlock Text="Map Preview" FontSize="10" Foreground="#4B5563" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Column 1: Selection Lists & Placeholders -->
                            <Grid Grid.Column="1">
                                <!-- Empty state text helper -->
                                <Border x:Name="border_no_results"
                                        Background="Transparent" 
                                        VerticalAlignment="Center" 
                                        HorizontalAlignment="Center"
                                        Padding="16">
                                    <TextBlock Text="Enter an address above and click Search to find parcels"
                                               Foreground="#9CA3AF" 
                                               TextWrapping="Wrap" 
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               FontSize="12"
                                               FontStyle="Italic"/>
                                </Border>

                                <!-- Custom Radio Button Style List View -->
                                <ListView x:Name="lv_parcels"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          SelectionMode="Single"
                                          Visibility="Collapsed"
                                          SelectionChanged="lv_parcels_SelectionChanged">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="8,10"/>
                                            <Setter Property="Margin" Value="0,2"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                Padding="{TemplateBinding Padding}"
                                                                CornerRadius="4"
                                                                Cursor="Hand">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F3F4F6"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Custom Radio Circle visual matches standard RadioButton -->
                                                <Grid Grid.Column="0" Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                                    <Ellipse Stroke="#D1D5DB" StrokeThickness="2" Fill="White" x:Name="outerRing"/>
                                                    <Ellipse Fill="#2563EB" Width="8" Height="8" Visibility="Collapsed" x:Name="dot"/>
                                                </Grid>

                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding display_address}" 
                                                           FontSize="13" 
                                                           Foreground="#1F2937" 
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"/>
                                            </Grid>

                                            <!-- Trigger to checked radio button visuals upon selection -->
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                    <Setter TargetName="outerRing" Property="Stroke" Value="#2563EB"/>
                                                    <Setter TargetName="dot" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Grid>
                    </GroupBox>

                    <!-- ─── REVIT CREATION OPTIONS CARD ─── -->
                    <GroupBox Header="Revit Creation Options" Style="{StaticResource PremiumCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <Grid.ColumnDefinition Width="*"/>
                                <Grid.ColumnDefinition Width="*"/>
                                <Grid.ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Elevation (ft)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="txt_elevation" Text="0.0"
                                         Style="{StaticResource InputField}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Line Category" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cmb_line_type"
                                          Background="White"
                                          Foreground="#1F2937"
                                          BorderBrush="#D1D5DB"
                                          Padding="10,8"
                                          ToolTip="Note: Revit API does not support direct PropertyLine creation.">
                                    <ComboBoxItem Content="Model Lines" IsSelected="True"/>
                                    <ComboBoxItem Content="Detail Lines"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Origin" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="cmb_origin"
                                          Background="White"
                                          Foreground="#1F2937"
                                          BorderBrush="#D1D5DB"
                                          Padding="10,8">
                                    <ComboBoxItem Content="Project Base Point" IsSelected="True"/>
                                    <ComboBoxItem Content="Survey Point"/>
                                    <ComboBoxItem Content="World Origin (0,0,0)"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ COMBINED BOTTOM BAR -->
        <Border Grid.Row="2" Background="#F8F9FA"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status panel on the left -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txt_status"
                               Text="Ready. Enter an address to begin."
                               Foreground="#4B5563"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    
                    <!-- Circle status separator dot -->
                    <Ellipse x:Name="dot_status"
                             Width="6" Height="6"
                             Fill="#6B7280"
                             VerticalAlignment="Center"
                             Margin="12,0"/>
                    
                    <TextBlock x:Name="txt_status_label"
                               Text="Idle"
                               Foreground="#4B5563"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Close & Action Buttons inline on the right -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btn_cancel"
                            Content="Close"
                            Width="90"
                            Style="{StaticResource SecondaryButton}"
                            Click="btn_close_Click"
                            Margin="0,0,12,0"/>
                    
                    <Button x:Name="btn_create"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            Click="btn_create_Click"
                            Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <!-- Location pin Segoe glyph inside blue button text -->
                            <TextBlock Text="&#xE707;" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       FontSize="12" 
                                       Margin="0,0,8,0" 
                                       VerticalAlignment="Center"
                                       Foreground="White"/>
                            <TextBlock Text="Create Property Lines in Revit" 
                                       VerticalAlignment="Center" 
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Verbatim standardized T3Lab copyright notice overlay -->
        <!-- Copyright added automatically -->
        <TextBlock Text="© Copyright by T3Lab" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,8" Foreground="#3498DB" FontSize="11" IsHitTestVisible="False" Panel.ZIndex="999"/>
    </Grid>
</Window>
