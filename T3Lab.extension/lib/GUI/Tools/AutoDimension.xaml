<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Dimension"
        Width="520" Height="480"
        MinWidth="480" MinHeight="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="White"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ── Section Header ── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ── GroupBox override ── -->
        <Style x:Key="SectionGroup" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8,12,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ── Primary Button ── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Secondary Button ── -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D5DBDB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Danger Button ── -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Success Button ── -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#219A52"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Window Control Button ── -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#ECF0F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close Button (red on hover) ── -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="64"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Action bar -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  TITLE BAR                                      -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="White" Height="64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo + Brand + Tool name + Subtitle -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="16,0,0,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">

                <!-- T3Lab logo image (loaded from code via _load_logo) -->
                <Image x:Name="logo_image"
                       Width="32" Height="32"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- Brand + Tool name + Subtitle stacked -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="T3Lab Architect"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#3498DB"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,8,2"/>
                        <TextBlock Text="Auto Dimension"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                    </StackPanel>
                    <Separator Height="1" Background="#BDC3C7" Margin="0,2,0,2"/>
                    <TextBlock Text="Auto-dimension walls, columns, doors, lifts &amp; grids in current view"
                               FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>

            <!-- Window control buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">

                <!-- Minimize -->
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WindowControlButton}"
                        ToolTip="Minimize"
                        Click="minimize_button_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>

                <!-- Maximize / Restore -->
                <Button x:Name="btn_maximize"
                        Style="{StaticResource WindowControlButton}"
                        ToolTip="Maximize"
                        Click="maximize_button_clicked">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>

                <!-- Close -->
                <Button x:Name="btn_close_chrome"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close"
                        Click="close_button_clicked">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#005B82"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver,
                                                 RelativeSource={RelativeSource AncestorType=Button}}"
                                                 Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  MAIN CONTENT                                   -->
        <!-- ═══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0">
            <StackPanel Margin="18,14,18,10">

                <!-- ─────────────────────────────────────── -->
                <!--  Section 1: Element Types               -->
                <!-- ─────────────────────────────────────── -->
                <GroupBox Header="Element Types"
                          Style="{StaticResource SectionGroup}">
                    <StackPanel>
                        <CheckBox x:Name="chk_walls"
                                  Content="Walls (from core layer)"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_struct_columns"
                                  Content="Structural Columns"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_arch_columns"
                                  Content="Architectural Columns"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_grids"
                                  Content="Grids"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_doors"
                                  Content="Doors (outer reference planes)"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_lifts"
                                  Content="Lifts / Mechanical Equipment"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- ─────────────────────────────────────── -->
                <!--  Section 3: Dimension Type              -->
                <!-- ─────────────────────────────────────── -->
                <GroupBox Header="Linear Dimension Type"
                          Style="{StaticResource SectionGroup}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Linear Dim Style:"
                                   FontSize="13"
                                   Foreground="#2C3E50"
                                   VerticalAlignment="Center"/>

                        <ComboBox x:Name="cmb_dim_type"
                                  Grid.Column="1"
                                  Height="28"
                                  FontSize="12"
                                  Foreground="#2C3E50"
                                  BorderBrush="#BDC3C7"
                                  BorderThickness="1"
                                  VerticalContentAlignment="Center">
                            <!-- Items are populated from code -->
                            <ComboBoxItem Content="Select dimension type..."
                                          IsEnabled="False"
                                          IsSelected="True"
                                          Foreground="#7F8C8D"/>
                        </ComboBox>
                    </Grid>
                </GroupBox>

                <!-- ─────────────────────────────────────── -->
                <!--  Section 4: Offset                      -->
                <!-- ─────────────────────────────────────── -->
                <GroupBox Header="Offset"
                          Style="{StaticResource SectionGroup}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Dimension Line Offset:"
                                   FontSize="13"
                                   Foreground="#2C3E50"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <TextBox x:Name="txt_offset"
                                 Grid.Column="1"
                                 Text="1000"
                                 Height="28"
                                 FontSize="13"
                                 Foreground="#2C3E50"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center"
                                 Padding="6,0"
                                 Margin="0,0,8,0"/>

                        <TextBlock Grid.Column="2"
                                   Text="mm"
                                   FontSize="13"
                                   Foreground="#7F8C8D"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </GroupBox>

                <!-- ─────────────────────────────────────── -->
                <!--  Info box                               -->
                <!-- ─────────────────────────────────────── -->
                <Border Background="#E8F4F8"
                        BorderBrush="#AED6F1"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,10"
                        Margin="0,2,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="#2980B9"
                                   VerticalAlignment="Top"
                                   Margin="0,1,10,0"/>
                        <TextBlock Text="Uses Linear dimension only. Walls: core layer faces. Doors: outer Left/Right reference planes. Each element dimensions to its nearest grid."
                                   FontSize="12"
                                   Foreground="#1A5276"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  ACTION BAR                                     -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Run button -->
                <Button x:Name="btn_run"
                        Grid.Column="0"
                        Content="Run Auto Dimension"
                        Style="{StaticResource PrimaryButton}"
                        Click="run_clicked"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Stretch"/>

                <!-- Close button -->
                <Button x:Name="btn_close"
                        Grid.Column="1"
                        Content="Close"
                        Style="{StaticResource SecondaryButton}"
                        Click="close_clicked"
                        Width="90"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  STATUS BAR                                     -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#FAFAFA"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="18,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="status_text"
                           Grid.Column="0"
                           Text="Ready"
                           FontSize="11"
                           Foreground="#7F8C8D"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="© T3Lab Architect"
                           FontSize="11"
                           Foreground="#BDC3C7"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
