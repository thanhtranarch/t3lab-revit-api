<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Dimension"
        Width="520" Height="720"
        MinWidth="480" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="White"
        FontFamily="Inter">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- ── Section Header ── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ── GroupBox override ── -->
        <Style x:Key="SectionGroup" TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8,12,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontFamily" Value="Inter"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- ── Primary Button ── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#083D56"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#062A3C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#546E7A"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Secondary Button ── -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E6EA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Danger Button ── -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Success Button ── -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Window Control Button ── -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close Button (red on hover) ── -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="64"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Action bar -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  TITLE BAR                                      -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="White" Height="64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo + Brand + Tool name + Subtitle -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="16,0,0,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">



                <!-- Brand + Tool name + Subtitle stacked -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="T3Lab"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#083D56"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,8,2"/>
                        <TextBlock Text="Auto Dimension"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                    </StackPanel>
                    <Separator Height="1" Background="#546E7A" Margin="0,2,0,2"/>
                    <TextBlock Text="Shop drawing string dimensions — walls, columns, doors, lifts &amp; grids"
                               FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>

            <!-- Window control buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">

                <!-- Minimize -->
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Minimize"
                        Click="minimize_button_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>

                <!-- Maximize / Restore -->
                <Button x:Name="btn_maximize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Maximize"
                        Click="maximize_button_clicked">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>

                <!-- Close -->
                <Button x:Name="btn_close_chrome"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close"
                        Click="close_button_clicked">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#083D56"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver,
                                                 RelativeSource={RelativeSource AncestorType=Button}}"
                                                 Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  MAIN CONTENT                                   -->
        <!-- ═══════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0">
            <StackPanel Margin="18,14,18,10">

                <!-- ─────────────────────────────────────── -->
                <!--  Section 0: Checking Mode               -->
                <!-- ─────────────────────────────────────── -->
                <GroupBox Header="Checking Mode"
                          Style="{StaticResource SectionGroup}">
                    <StackPanel>
                        <CheckBox x:Name="chk_checking_mode"
                                  Content="Enable Checking Mode — align to nearest grid only"
                                  IsChecked="False"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,2,0,6"
                                  Checked="checking_mode_changed"
                                  Unchecked="checking_mode_changed"/>
                        <Grid x:Name="pnl_check_dim_type" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Check dim style:"
                                       FontSize="13"
                                       Foreground="#2C3E50"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmb_check_dim_type"
                                      Grid.Column="1"
                                      Height="28"
                                      FontSize="12"
                                      Foreground="#2C3E50"
                                      BorderBrush="#546E7A"
                                      BorderThickness="1"
                                      VerticalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- ─────────────────────────────────────── -->
                <!--  Section 1: Element Types               -->
                <!-- ─────────────────────────────────────── -->
                <GroupBox Header="Element Types"
                          Style="{StaticResource SectionGroup}">
                    <StackPanel>
                        <CheckBox x:Name="chk_walls"
                                  Content="Walls (from core layer)"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_struct_columns"
                                  Content="Structural Columns"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_arch_columns"
                                  Content="Architectural Columns"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_grids"
                                  Content="Grid-to-Grid Overall Chains"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_windows"
                                  Content="Windows (opening width)"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_doors"
                                  Content="Doors (opening width)"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,4"/>
                        <CheckBox x:Name="chk_lifts"
                                  Content="Lifts / Mechanical Equipment"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,4,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- ─────────────────────────────────────── -->
                <!--  Section 2: Wall Reference Layer        -->
                <!-- ─────────────────────────────────────── -->
                <GroupBox x:Name="grp_wall_layer"
                          Header="Wall Reference Layer"
                          Style="{StaticResource SectionGroup}">
                    <StackPanel IsEnabled="{Binding IsChecked, ElementName=chk_walls}">
                        <TextBlock Text="Dimension walls to:"
                                   FontSize="12"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,6"/>
                        <RadioButton x:Name="rad_wall_ext"
                                     Content="Exterior face"
                                     IsChecked="True"
                                     GroupName="WallLayer"
                                     FontSize="13"
                                     Foreground="#2C3E50"
                                     Margin="0,3,0,3"/>
                        <RadioButton x:Name="rad_wall_int"
                                     Content="Interior face"
                                     GroupName="WallLayer"
                                     FontSize="13"
                                     Foreground="#2C3E50"
                                     Margin="0,3,0,3"/>
                        <RadioButton x:Name="rad_wall_both"
                                     Content="Both faces  (dim string shows wall thickness)"
                                     GroupName="WallLayer"
                                     FontSize="13"
                                     Foreground="#2C3E50"
                                     Margin="0,3,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- ─────────────────────────────────────── -->
                <!--  Section 3: Dimension Type              -->
                <!-- ─────────────────────────────────────── -->
                <GroupBox x:Name="grp_dim_type"
                          Header="Linear Dimension Type"
                          Style="{StaticResource SectionGroup}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Linear Dim Style:"
                                   FontSize="13"
                                   Foreground="#2C3E50"
                                   VerticalAlignment="Center"/>

                        <ComboBox x:Name="cmb_dim_type"
                                  Grid.Column="1"
                                  Height="28"
                                  FontSize="12"
                                  Foreground="#2C3E50"
                                  BorderBrush="#546E7A"
                                  BorderThickness="1"
                                  VerticalContentAlignment="Center">
                            <!-- Items are populated from code -->
                            <ComboBoxItem Content="Select dimension type..."
                                          IsEnabled="False"
                                          IsSelected="True"
                                          Foreground="#7F8C8D"/>
                        </ComboBox>
                    </Grid>
                </GroupBox>

                <!-- ─────────────────────────────────────── -->
                <!--  Section 4: Dimension Settings          -->
                <!-- ─────────────────────────────────────── -->
                <GroupBox x:Name="grp_dim_settings"
                          Header="Dimension Settings"
                          Style="{StaticResource SectionGroup}">
                    <StackPanel>

                        <!-- Offset Mode row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Offset mode:"
                                       FontSize="13"
                                       Foreground="#2C3E50"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmb_offset_mode"
                                      Grid.Column="1"
                                      Height="28"
                                      FontSize="12"
                                      Foreground="#2C3E50"
                                      BorderBrush="#546E7A"
                                      BorderThickness="1"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="offset_mode_changed">
                                <ComboBoxItem Content="Single offset" IsSelected="True"/>
                                <ComboBoxItem Content="3-Level auto (L1 / L2 / L3)"/>
                            </ComboBox>
                        </Grid>

                        <!-- Single offset panel -->
                        <Grid x:Name="pnl_single_offset" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Offset distance:"
                                       FontSize="13"
                                       Foreground="#2C3E50"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="txt_offset"
                                     Grid.Column="1"
                                     Text="1000"
                                     Height="28"
                                     FontSize="13"
                                     Foreground="#2C3E50"
                                     BorderBrush="#546E7A"
                                     BorderThickness="1"
                                     VerticalContentAlignment="Center"
                                     Padding="6,0"
                                     Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="mm"
                                       FontSize="13"
                                       Foreground="#7F8C8D"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 3-Level offsets panel -->
                        <StackPanel x:Name="pnl_3level_offsets"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,8">
                            <!-- L1 -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="L1 — Openings:"
                                           FontSize="13"
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="txt_l1"
                                         Grid.Column="1"
                                         Text="500"
                                         Height="28"
                                         FontSize="13"
                                         Foreground="#2C3E50"
                                         BorderBrush="#546E7A"
                                         BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         Padding="6,0"
                                         Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="mm"
                                           FontSize="13"
                                           Foreground="#7F8C8D"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <!-- L2 -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="L2 — Columns/Walls:"
                                           FontSize="13"
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="txt_l2"
                                         Grid.Column="1"
                                         Text="1000"
                                         Height="28"
                                         FontSize="13"
                                         Foreground="#2C3E50"
                                         BorderBrush="#546E7A"
                                         BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         Padding="6,0"
                                         Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="mm"
                                           FontSize="13"
                                           Foreground="#7F8C8D"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <!-- L3 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="L3 — Grid overall:"
                                           FontSize="13"
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="txt_l3"
                                         Grid.Column="1"
                                         Text="1500"
                                         Height="28"
                                         FontSize="13"
                                         Foreground="#2C3E50"
                                         BorderBrush="#546E7A"
                                         BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         Padding="6,0"
                                         Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="mm"
                                           FontSize="13"
                                           Foreground="#7F8C8D"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Direction row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Direction:"
                                       FontSize="13"
                                       Foreground="#2C3E50"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmb_direction"
                                      Grid.Column="1"
                                      Height="28"
                                      FontSize="12"
                                      Foreground="#2C3E50"
                                      BorderBrush="#546E7A"
                                      BorderThickness="1"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="Both X and Y" IsSelected="True"/>
                                <ComboBoxItem Content="X only (above / below)"/>
                                <ComboBoxItem Content="Y only (left / right)"/>
                            </ComboBox>
                        </Grid>

                        <!-- Both sides checkbox -->
                        <CheckBox x:Name="chk_both_sides"
                                  Content="Mirror dim strings to both sides of building"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  Margin="0,0,0,8"/>

                        <!-- Conflict warning row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="chk_min_seg"
                                      Grid.Column="0"
                                      Content="Warn if segment &lt; "
                                      IsChecked="True"
                                      FontSize="13"
                                      Foreground="#2C3E50"
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0"/>
                            <TextBox x:Name="txt_min_seg"
                                     Grid.Column="1"
                                     Text="300"
                                     Height="28"
                                     Width="60"
                                     FontSize="13"
                                     Foreground="#2C3E50"
                                     BorderBrush="#546E7A"
                                     BorderThickness="1"
                                     VerticalContentAlignment="Center"
                                     HorizontalAlignment="Left"
                                     Padding="6,0"
                                     Margin="0,0,6,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="mm"
                                       FontSize="13"
                                       Foreground="#7F8C8D"
                                       VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </GroupBox>

                <!-- ─────────────────────────────────────── -->
                <!--  Info box                               -->
                <!-- ─────────────────────────────────────── -->
                <Border x:Name="brd_info"
                        Background="#F8F9FA"
                        BorderBrush="#083D56"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,10"
                        Margin="0,2,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="#062A3C"
                                   VerticalAlignment="Top"
                                   Margin="0,1,10,0"/>
                        <TextBlock Text="3-level nested dims: ① Inner (0.5× offset) — windows + doors in each structural row. ② Mid (1× offset) — column string per row. ③ Outer (2× offset) — grid-to-grid overall. Wall Reference Layer controls which face of each wall is used."
                                   FontSize="12"
                                   Foreground="#2C3E50"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  ACTION BAR                                     -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#546E7A"
                BorderThickness="0,1,0,0"
                Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Run button -->
                <Button x:Name="btn_run"
                        Grid.Column="0"
                        Content="Run Auto Dimension"
                        Style="{StaticResource PrimaryButton}"
                        Click="run_clicked"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Stretch"/>

                <!-- Close button -->
                <Button x:Name="btn_close"
                        Grid.Column="1"
                        Content="Close"
                        Style="{StaticResource SecondaryButton}"
                        Click="close_clicked"
                        Width="90"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  STATUS BAR                                     -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#F8F9FA"
                BorderBrush="#546E7A"
                BorderThickness="0,1,0,0"
                Padding="18,0">
            <TextBlock x:Name="status_text"
                       Text="Ready"
                       FontSize="11"
                       Foreground="#7F8C8D"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Copyright added automatically -->
        <TextBlock Text="© Copyright by T3Lab" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,8" Foreground="#3498DB" FontSize="11" IsHitTestVisible="False" Panel.ZIndex="999"/>
    </Grid>
</Window>
