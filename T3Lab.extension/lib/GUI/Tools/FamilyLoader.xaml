<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid.Resources>

        <!-- Window control button (minimize) -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="19"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window control button (close) -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="19"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Folder / small action button -->
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="#083D56"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#062A3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#546E7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary small button (Select None / grey) -->
        <Style x:Key="SmallBtnGrey" TargetType="Button" BasedOn="{StaticResource SmallBtn}">
            <Setter Property="Background" Value="#7F8C8D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary Load button -->
        <Style x:Key="LoadBtn" TargetType="Button">
            <Setter Property="Width" Value="130"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#083D56"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="3"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#062A3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#546E7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cancel button -->
        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#546E7A" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="3,2"/>
        </Style>

    </Grid.Resources>

    <!-- ════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- 0 Title bar -->
            <RowDefinition Height="50"/>   <!-- 1 Search bar -->
            <RowDefinition Height="44"/>   <!-- 2 Folder / source bar -->
            <RowDefinition Height="*"/>    <!-- 3 Main content -->
            <RowDefinition Height="62"/>   <!-- 4 Footer -->
        </Grid.RowDefinitions>

        <!-- ══ ROW 0 — TITLE BAR ══════════════════════ -->
        <Border Grid.Row="0" x:Name="title_bar_grid"
                Background="White"
                BorderBrush="#546E7A" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Vertical"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                                   Foreground="#083D56" VerticalAlignment="Bottom"
                                   Margin="0,0,6,3"/>
                        <TextBlock Text="Load Family" FontSize="18" FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                    </StackPanel>
                    <Separator Height="1" Background="#546E7A" Margin="0,2,0,2"/>
                    <TextBlock Text="Load Revit families from local folders or cloud"
                               FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
                </StackPanel>

                <!-- Window control buttons
                     CaptionHeight=0 in Python means these are in normal client area
                     and receive mouse events without IsHitTestVisibleInChrome -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,6,0">
                    <Button x:Name="btn_minimize_fl"
                            Style="{StaticResource WinCtrlButton}"
                            ToolTip="Minimize">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"
                                   Margin="0,-1,0,0"/>
                    </Button>
                    <Button x:Name="btn_close_x_fl"
                            Style="{StaticResource CloseButton}"
                            ToolTip="Close">
                        <!-- X drawn as a Path so it scales cleanly -->
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ ROW 1 — SEARCH BAR ════════════════════ -->
        <Border Grid.Row="1" Background="White" Padding="14,7"
                BorderBrush="#546E7A" BorderThickness="0,0,0,1">
            <Border BorderBrush="#546E7A" BorderThickness="1" CornerRadius="8"
                    Background="White">
                <DockPanel>
                    <!-- magnifier icon (Unicode circle + line) -->
                    <TextBlock DockPanel.Dock="Left"
                               Text="&#9740;" FontSize="16" Foreground="#7F8C8D"
                               VerticalAlignment="Center" Margin="10,0,2,0"/>
                    <TextBox x:Name="txt_search"
                             BorderThickness="0" Background="Transparent"
                             VerticalContentAlignment="Center"
                             FontSize="13" Foreground="#2C3E50"
                             Padding="6,0,8,0" Height="34"/>
                </DockPanel>
            </Border>
        </Border>

        <!-- ══ ROW 2 — FOLDER / SOURCE BAR ══════════ -->
        <Border Grid.Row="2" Background="#F8F9FA" Padding="12,0"
                BorderBrush="#546E7A" BorderThickness="0,0,0,1">
            <DockPanel VerticalAlignment="Center">
                <!-- Source radio buttons on the right -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="Source:" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontSize="11.5" Foreground="#7F8C8D"/>
                    <RadioButton x:Name="radio_local" Content="Local"
                                 GroupName="DataSource" IsChecked="True"
                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                 FontSize="11.5"/>
                    <RadioButton x:Name="radio_cloud" Content="Cloud (Vercel)"
                                 GroupName="DataSource"
                                 IsEnabled="False"
                                 VerticalAlignment="Center" Margin="0,0,6,0"
                                 FontSize="11.5"
                                 ToolTip="Cloud feature is currently disabled"/>
                </StackPanel>
                <!-- Folder button + path on the left -->
                <Button x:Name="btn_select_folder"
                        Content="Update Folder"
                        Style="{StaticResource SmallBtn}"
                        DockPanel.Dock="Left"/>
                <TextBlock x:Name="txt_current_folder"
                           Text="No folder selected"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" FontSize="11.5"
                           Foreground="#7F8C8D"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- ══ ROW 3 — MAIN CONTENT ═════════════════ -->
        <DockPanel Grid.Row="3">

            <!-- Left: Category tree (slim) -->
            <Border DockPanel.Dock="Left" Width="190"
                    BorderBrush="#546E7A" BorderThickness="0,0,1,0"
                    Background="#F8F9FA">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F4F6F7"
                            Padding="12,6" BorderBrush="#546E7A" BorderThickness="0,0,0,1">
                        <TextBlock Text="Categories" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#2C3E50"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TreeView x:Name="tree_categories"
                                  BorderThickness="0" Background="Transparent"
                                  Padding="4"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Right: Grid area -->
            <DockPanel>
                <!-- Sub-header: count + select buttons -->
                <Border DockPanel.Dock="Top" Padding="12,6"
                        Background="#F8F9FA"
                        BorderBrush="#546E7A" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock x:Name="txt_result_count"
                                   Text="0 families found"
                                   VerticalAlignment="Center"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#2C3E50"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right">
                            <Button x:Name="btn_select_all"
                                    Content="Select All"
                                    Style="{StaticResource SmallBtn}"
                                    Margin="0,0,6,0"/>
                            <Button x:Name="btn_select_none"
                                    Content="Select None"
                                    Style="{StaticResource SmallBtnGrey}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Family cards — reference-style layout -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Padding="10,10,10,6">
                    <ItemsControl x:Name="items_families">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Per-card container: card border + name below -->
                                <StackPanel Width="155" Margin="5,5,5,2">

                                    <!-- Card — reference style: rounded border, thumbnail fills it -->
                                    <Border Height="148" CornerRadius="8" Cursor="Hand">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="#546E7A"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <!-- Blue border + slightly thicker when selected -->
                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#083D56"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                        <Setter Property="Background" Value="#F8F9FA"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="#083D56"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <!-- Grey background so empty thumbnail area looks clean -->
                                            <Border Background="#F8F9FA" CornerRadius="7" Margin="1"/>
                                            <!-- Thumbnail image -->
                                            <Image Source="{Binding Thumbnail}"
                                                   Stretch="Uniform" Margin="10"/>
                                            <!-- Checkbox overlay — top left -->
                                            <CheckBox IsChecked="{Binding IsChecked}"
                                                      VerticalAlignment="Top"
                                                      HorizontalAlignment="Left"
                                                      Margin="7,7,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- Name below the card border (like reference image) -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="11" Foreground="#2C3E50"
                                               TextWrapping="Wrap" MaxHeight="34"
                                               Margin="3,4,3,0"
                                               ToolTip="{Binding FullPath}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </DockPanel>

        <!-- ══ ROW 4 — FOOTER ═══════════════════════ -->
        <Border Grid.Row="4" Background="White"
                BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel VerticalAlignment="Center">
                <!-- Copyright left -->
                <TextBlock DockPanel.Dock="Left"
                           Text="&#169; Copyright by T3Lab"
                           VerticalAlignment="Center"
                           FontSize="10" Foreground="#7F8C8D"/>
                <!-- Buttons right -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <TextBlock x:Name="txt_selected_count"
                               Text="0 families selected"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0"
                               FontSize="12" Foreground="#7F8C8D"/>
                    <Button x:Name="btn_load"
                            Content="Load"
                            Style="{StaticResource LoadBtn}"
                            Margin="0,0,10,0"
                            IsEnabled="False"/>
                    <Button x:Name="btn_cancel"
                            Content="Cancel"
                            Style="{StaticResource CancelBtn}"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
        <TextBlock Text="© Copyright by T3Lab" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,8" Foreground="#3498DB" FontSize="11" IsHitTestVisible="False" Panel.ZIndex="999"/>
</Grid>
