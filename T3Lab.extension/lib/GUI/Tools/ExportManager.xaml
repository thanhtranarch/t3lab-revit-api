<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BatchOut"
        Width="1280" Height="780"
        MinWidth="1200" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="White"
        FontFamily="Inter">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Styles -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#083D56"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#062A3C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#546E7A"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E6EA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormatCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <!-- Window Control Button Style -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Close Button Style (Red on hover) -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StepCircle" TargetType="Border">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#546E7A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,18,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="White" Height="64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#083D56" VerticalAlignment="Bottom" Margin="0,0,6,3"/>
                    <TextBlock Text="BatchOut" FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                </StackPanel>
                <Separator Height="1" Background="#546E7A" Margin="0,2,0,2"/>
                <TextBlock Text="Batch export sheets to multiple formats with advanced options"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <!-- Window Control Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Profile Button -->
                <Button x:Name="btn_profile"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Profiles"
                        Click="profile_button_clicked">
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#083D56"/>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="6,8" Background="#F8F9FA"/>

                <!-- Minimize Button -->
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Minimize"
                        Click="minimize_button_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>

                <!-- Maximize/Restore Button -->
                <Button x:Name="btn_maximize"
                        Style="{StaticResource WinCtrlButton}"
                        ToolTip="Maximize"
                        Click="maximize_button_clicked">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>

                <!-- Close Button -->
                <Button x:Name="btn_close"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close"
                        Click="close_button_clicked">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>

            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="20,10,20,20">

            <!-- Tab Control -->
            <Grid>
                <TabControl Margin="0,0,0,0" x:Name="main_tabs">

            <!-- Selection Tab -->
            <TabItem Header="Selection" Style="{StaticResource TabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Select Sheets or Views to Export" Style="{StaticResource SectionHeader}"/>


                    <!-- Selection Controls -->
                    <Grid Grid.Row="1" Margin="0,5">
                        <!-- Single Row with Sheets/Views Radio Buttons, View/Sheet Set, Save V/S Set, and Search -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <!-- Radio Buttons for Sheets/Views -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton x:Name="sheets_radio" Content="Sheets" GroupName="selectionMode"
                                             IsChecked="True" Margin="0,0,20,0"
                                             Checked="selection_mode_changed" FontWeight="Medium"/>
                                <RadioButton x:Name="views_radio" Content="Views" GroupName="selectionMode"
                                             Checked="selection_mode_changed" FontWeight="Medium"/>
                            </StackPanel>

                            <!-- View Type Filter (for Views) - Hidden by default -->
                            <ComboBox Grid.Column="1" x:Name="view_type_filter" Height="28"
                                      SelectionChanged="filter_by_size" Visibility="Collapsed"
                                      VerticalAlignment="Center" Width="150" Margin="20,0,0,0">
                                <ComboBoxItem Content="All Views" IsSelected="True"/>
                                <ComboBoxItem Content="Floor Plan"/>
                                <ComboBoxItem Content="Ceiling Plan"/>
                                <ComboBoxItem Content="Elevation"/>
                                <ComboBoxItem Content="Section"/>
                                <ComboBoxItem Content="3D View"/>
                                <ComboBoxItem Content="Schedule"/>
                                <ComboBoxItem Content="Drafting"/>
                                <ComboBoxItem Content="Legend"/>
                                <ComboBoxItem Content="Engineering"/>
                                <ComboBoxItem Content="Area Plan"/>
                            </ComboBox>

                            <!-- View/Sheet Set - multi-select dropdown -->
                            <TextBlock Grid.Column="3" Text="View/Sheet Set:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <Grid Grid.Column="4">
                                <ToggleButton x:Name="sheet_set_toggle"
                                              Height="28"
                                              HorizontalContentAlignment="Left"
                                              Padding="8,0,26,0"
                                              BorderBrush="#546E7A" BorderThickness="1"
                                              Background="White" Cursor="Hand"
                                              Click="sheet_set_toggle_clicked"
                                              ToolTip="Click to select one or more View/Sheet Sets">
                                    <TextBlock x:Name="sheet_set_label" Text="All Sheets/Views"
                                               VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                                </ToggleButton>
                                <TextBlock Text="▾" VerticalAlignment="Center" HorizontalAlignment="Right"
                                           Margin="0,0,8,0" IsHitTestVisible="False"
                                           Foreground="#7F8C8D" FontSize="10"/>
                                <Popup x:Name="sheet_set_popup"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       PlacementTarget="{Binding ElementName=sheet_set_toggle}"
                                       Placement="Bottom">
                                    <Border BorderBrush="#546E7A" BorderThickness="1"
                                            Background="White" MinWidth="240" MaxHeight="220">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="sheet_set_checklist" Margin="4,6,4,6"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <!-- Save V/S Set Button -->
                            <Button Grid.Column="6" x:Name="save_vs_set_button"
                                    Content="Save V/S Set"
                                    Height="28"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="save_vs_set_clicked"
                                    ToolTip="Save current selection as View/Sheet Set"/>

                            <!-- Search Box -->
                            <TextBlock Grid.Column="8" Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="9" x:Name="search_textbox" Height="28"
                                     VerticalContentAlignment="Center"
                                     TextChanged="search_sheets"/>
                        </Grid>
                    </Grid>

                    <!-- Sheets List with Selection Status -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#546E7A" BorderThickness="1" Margin="0,5" CornerRadius="3" Background="#F4F6F7">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <ListView Grid.Row="1" x:Name="sheets_listview"
                                          SelectionMode="Extended"
                                          BorderThickness="0"
                                          MouseDoubleClick="listview_item_double_clicked"
                                          SizeChanged="on_listview_size_changed">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView x:Name="items_gridview">
                                            <GridViewColumn Width="40">
                                                <GridViewColumn.Header>
                                                    <CheckBox x:Name="header_checkbox"
                                                              HorizontalAlignment="Center"
                                                              ToolTip="Select All / Deselect All"
                                                              Click="header_checkbox_clicked"/>
                                                </GridViewColumn.Header>
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  HorizontalAlignment="Center"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn x:Name="col_number" Header="Sheet Number" Width="150"
                                                            DisplayMemberBinding="{Binding SheetNumber}"/>
                                            <GridViewColumn x:Name="col_name" Header="Sheet Name" Width="250"
                                                            DisplayMemberBinding="{Binding SheetName}"/>
                                            <GridViewColumn x:Name="col_revision" Header="Revision" Width="80"
                                                            DisplayMemberBinding="{Binding Revision}"/>
                                            <GridViewColumn x:Name="col_size" Header="Size" Width="80"
                                                            DisplayMemberBinding="{Binding Size}"/>
                                            <GridViewColumn x:Name="col_orientation" Header="Orientation" Width="90"
                                                            DisplayMemberBinding="{Binding Orientation}"/>
                                            <GridViewColumn x:Name="col_custom_filename" Width="280">
                                                <GridViewColumn.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Custom Filename" VerticalAlignment="Center"/>
                                                        <Button x:Name="btn_edit_filename"
                                                                Content="Edit"
                                                                Height="20"
                                                                Padding="8,2"
                                                                FontSize="10"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Click="edit_filename_clicked"
                                                                ToolTip="Edit filename pattern for all items"
                                                                Margin="10,0,0,0"/>
                                                    </StackPanel>
                                                </GridViewColumn.Header>
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding CustomFilename, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 BorderThickness="1" BorderBrush="#F8F9FA" Padding="4,2"
                                                                 ToolTip="Custom filename (leave empty to use pattern)"
                                                                 PreviewMouseLeftButtonDown="textbox_prevent_toggle"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </Border>

                        <!-- Selection Count Status Bar -->
                        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#546E7A" BorderThickness="1"
                                Padding="10,8" Margin="0,5,0,0" CornerRadius="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="selection_count_text"
                                           Grid.Column="0"
                                           Text="0 sheets and 0 views selected. Total: 0"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Format Tab -->
            <TabItem Header="Format" Style="{StaticResource TabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" x:Name="format_panels_container">

                        <TextBlock Text="Select Formats &amp; Configure Settings" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Check a format to enable it. Click the header bar to expand/collapse its settings."
                                   FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,10"/>

                        <!-- ═══ PDF ═══ -->
                        <Border x:Name="pdf_panel_border" BorderBrush="#083D56" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,6">
                            <!-- Header row -->
                            <StackPanel>
                                <Border Background="#F8F9FA" CornerRadius="4,4,0,0" Cursor="Hand"
                                        MouseLeftButtonUp="pdf_header_clicked">
                                    <Grid Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="export_pdf" Grid.Column="0"
                                                  Content="PDF" IsChecked="True"
                                                  FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"
                                                  Checked="format_changed" Unchecked="format_changed"/>
                                        <TextBlock Grid.Column="1" Text="Portable Document Format"
                                                   FontSize="11" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <TextBlock x:Name="pdf_expand_arrow" Grid.Column="2"
                                                   Text="▾" FontSize="12" Foreground="#083D56"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <!-- PDF Settings Body -->
                                <Border x:Name="pdf_settings_body" Background="White"
                                        BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                                        Padding="15,10" CornerRadius="0,0,4,4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Paper Size:" VerticalAlignment="Center" Margin="0,5"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                                            <CheckBox x:Name="pdf_auto_detect_size" Content="Auto-detect from Title Block"
                                                      Margin="0,0,0,5" IsChecked="True"
                                                      Checked="pdf_auto_detect_changed" Unchecked="pdf_auto_detect_changed"/>
                                            <ComboBox x:Name="pdf_paper_size" Height="26" SelectedIndex="0" IsEnabled="False" MaxWidth="180" HorizontalAlignment="Left">
                                                <ComboBoxItem Content="Use Sheet Size"/>
                                                <ComboBoxItem Content="A0"/><ComboBoxItem Content="A1"/>
                                                <ComboBoxItem Content="A2"/><ComboBoxItem Content="A3"/>
                                                <ComboBoxItem Content="A4"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Orientation:" VerticalAlignment="Center" Margin="0,5"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="5">
                                            <RadioButton x:Name="pdf_landscape" Content="Landscape" GroupName="orientation"
                                                         IsChecked="True" Margin="0,0,20,0" IsEnabled="False"/>
                                            <RadioButton x:Name="pdf_portrait" Content="Portrait" GroupName="orientation" IsEnabled="False"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Zoom:" VerticalAlignment="Center" Margin="0,5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="5">
                                            <RadioButton x:Name="pdf_fit_to_page" Content="Fit to Page" GroupName="zoom"
                                                         IsChecked="True" Margin="0,0,20,0"/>
                                            <RadioButton x:Name="pdf_zoom_custom" Content="Custom Zoom" GroupName="zoom"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Options:" VerticalAlignment="Top" Margin="0,8,0,5"/>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="5,5,5,0">
                                            <CheckBox x:Name="pdf_hide_ref_planes" Content="Hide ref/work planes" Margin="0,3"/>
                                            <CheckBox x:Name="pdf_hide_scope_boxes" Content="Hide scope boxes" Margin="0,3"/>
                                            <CheckBox x:Name="pdf_hide_crop_boundaries" Content="Hide crop boundaries" Margin="0,3"/>
                                            <CheckBox x:Name="pdf_hide_unreferenced_tags" Content="Hide unreferenced view tags" Margin="0,3"/>
                                            <CheckBox x:Name="pdf_view_links_blue" Content="View links in blue" Margin="0,3"/>
                                            <CheckBox x:Name="combine_pdf" Content="Combine all sheets into single PDF"
                                                      FontWeight="SemiBold" Margin="0,8,0,3"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ═══ DWG ═══ -->
                        <Border x:Name="dwg_panel_border" BorderBrush="#546E7A" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,6">
                            <StackPanel>
                                <Border Background="#F8F9FA" CornerRadius="4,4,0,0" Cursor="Hand"
                                        MouseLeftButtonUp="dwg_header_clicked">
                                    <Grid Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="export_dwg" Grid.Column="0"
                                                  Content="DWG" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"
                                                  Checked="format_changed" Unchecked="format_changed"/>
                                        <TextBlock Grid.Column="1" Text="AutoCAD Drawing File"
                                                   FontSize="11" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <TextBlock x:Name="dwg_expand_arrow" Grid.Column="2"
                                                   Text="▾" FontSize="12" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border x:Name="dwg_settings_body" Background="White"
                                        BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                                        Padding="15,10" CornerRadius="0,0,4,4"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="AutoCAD Version:" VerticalAlignment="Center" Margin="0,5"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="dwg_version" Height="26" Margin="5" SelectedIndex="0" MaxWidth="200" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="AutoCAD 2013"/>
                                            <ComboBoxItem Content="AutoCAD 2010"/>
                                            <ComboBoxItem Content="AutoCAD 2007"/>
                                        </ComboBox>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Export Setup:" VerticalAlignment="Center" Margin="0,5"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cad_export_setup" Height="26" Margin="5" SelectedIndex="0" MaxWidth="300" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="Use setup from file"/>
                                        </ComboBox>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Options:" VerticalAlignment="Top" Margin="0,8,0,5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="5,8,5,0">
                                            <CheckBox x:Name="cad_export_views_on_sheets" Content="Export views on sheets" IsChecked="False" Margin="0,3"/>
                                            <CheckBox x:Name="cad_export_links_as_external" Content="Export links as external references" IsChecked="False" Margin="0,3"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ═══ DGN ═══ -->
                        <Border x:Name="dgn_panel_border" BorderBrush="#546E7A" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,6">
                            <StackPanel>
                                <Border Background="#F8F9FA" CornerRadius="4" Cursor="Hand"
                                        MouseLeftButtonUp="dgn_header_clicked">
                                    <Grid Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="export_dgn" Grid.Column="0"
                                                  Content="DGN" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"
                                                  Checked="format_changed" Unchecked="format_changed"/>
                                        <TextBlock Grid.Column="1" Text="MicroStation Design File"
                                                   FontSize="11" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <TextBlock x:Name="dgn_expand_arrow" Grid.Column="2"
                                                   Text="▾" FontSize="12" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border x:Name="dgn_settings_body" Background="White"
                                        BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                                        Padding="15,10" CornerRadius="0,0,4,4"
                                        Visibility="Collapsed">
                                    <TextBlock Text="Uses Revit's default DGN export settings. No additional configuration required."
                                               FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ═══ DWF ═══ -->
                        <Border x:Name="dwf_panel_border" BorderBrush="#546E7A" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,6">
                            <StackPanel>
                                <Border Background="#F8F9FA" CornerRadius="4" Cursor="Hand"
                                        MouseLeftButtonUp="dwf_header_clicked">
                                    <Grid Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="export_dwf" Grid.Column="0"
                                                  Content="DWF" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"
                                                  Checked="format_changed" Unchecked="format_changed"/>
                                        <TextBlock Grid.Column="1" Text="Design Web Format"
                                                   FontSize="11" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <TextBlock x:Name="dwf_expand_arrow" Grid.Column="2"
                                                   Text="▾" FontSize="12" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border x:Name="dwf_settings_body" Background="White"
                                        BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                                        Padding="15,10" CornerRadius="0,0,4,4"
                                        Visibility="Collapsed">
                                    <TextBlock Text="Uses Revit's default DWF export settings. No additional configuration required."
                                               FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ═══ NWC ═══ -->
                        <Border x:Name="nwc_panel_border" BorderBrush="#546E7A" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,6">
                            <StackPanel>
                                <Border Background="#F8F9FA" CornerRadius="4" Cursor="Hand"
                                        MouseLeftButtonUp="nwc_header_clicked">
                                    <Grid Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="export_nwd" Grid.Column="0"
                                                  Content="NWC" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"
                                                  Checked="format_changed" Unchecked="format_changed"
                                                  ToolTip="Requires Navisworks to be installed"/>
                                        <TextBlock Grid.Column="1" Text="Navisworks Cache File"
                                                   FontSize="11" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <TextBlock x:Name="nwc_expand_arrow" Grid.Column="2"
                                                   Text="▾" FontSize="12" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border x:Name="nwc_settings_body" Background="White"
                                        BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                                        Padding="15,10" CornerRadius="0,0,4,4"
                                        Visibility="Collapsed">
                                    <TextBlock Text="Exports each view/sheet as a separate NWC file. Requires Navisworks Exporters to be installed."
                                               FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ═══ IFC ═══ -->
                        <Border x:Name="ifc_panel_border" BorderBrush="#546E7A" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,6">
                            <StackPanel>
                                <Border Background="#F8F9FA" CornerRadius="4,4,0,0" Cursor="Hand"
                                        MouseLeftButtonUp="ifc_header_clicked">
                                    <Grid Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="export_ifc" Grid.Column="0"
                                                  Content="IFC" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"
                                                  Checked="format_changed" Unchecked="format_changed"/>
                                        <TextBlock Grid.Column="1" Text="Industry Foundation Classes"
                                                   FontSize="11" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <TextBlock x:Name="ifc_expand_arrow" Grid.Column="2"
                                                   Text="▾" FontSize="12" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border x:Name="ifc_settings_body" Background="White"
                                        BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                                        Padding="15,10" CornerRadius="0,0,4,4"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="IFC Version:" VerticalAlignment="Center" Margin="0,5"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ifc_version" Height="26" Margin="5" SelectedIndex="1" MaxWidth="160" HorizontalAlignment="Left">
                                            <ComboBoxItem Content="IFC 2x2"/>
                                            <ComboBoxItem Content="IFC 2x3"/>
                                            <ComboBoxItem Content="IFC 4"/>
                                        </ComboBox>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="Note: IFC exports the entire Revit model — one .ifc file regardless of sheet/view selection."
                                                   FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ═══ IMG ═══ -->
                        <Border x:Name="img_panel_border" BorderBrush="#546E7A" BorderThickness="1"
                                CornerRadius="4" Margin="0,0,0,6">
                            <StackPanel>
                                <Border Background="#F8F9FA" CornerRadius="4,4,0,0" Cursor="Hand"
                                        MouseLeftButtonUp="img_header_clicked">
                                    <Grid Margin="12,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="export_img" Grid.Column="0"
                                                  Content="IMG" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"
                                                  Checked="format_changed" Unchecked="format_changed"/>
                                        <TextBlock Grid.Column="1" Text="PNG / JPEG Image"
                                                   FontSize="11" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <TextBlock x:Name="img_expand_arrow" Grid.Column="2"
                                                   Text="▾" FontSize="12" Foreground="#7F8C8D"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <Border x:Name="img_settings_body" Background="White"
                                        BorderBrush="#546E7A" BorderThickness="0,1,0,0"
                                        Padding="15,10" CornerRadius="0,0,4,4"
                                        Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Image Size:" VerticalAlignment="Top" Margin="0,8"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <RadioButton x:Name="img_fit_to_page" Content="Fit to" GroupName="imgSize"
                                                             IsChecked="True" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBox x:Name="img_fit_pixels" Text="1080" Width="60" Height="24"
                                                         VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="pixels" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                                <TextBlock Text="Direction:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#7F8C8D"/>
                                                <RadioButton x:Name="img_dir_horizontal" Content="Horizontal" GroupName="imgDirection"
                                                             IsChecked="True" Margin="0,0,10,0"/>
                                                <RadioButton x:Name="img_dir_vertical" Content="Vertical" GroupName="imgDirection"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="img_zoom_to" Content="Zoom to" GroupName="imgSize"
                                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBox x:Name="img_zoom_percent" Text="50" Width="50" Height="24"
                                                         VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBlock Text="% of actual size" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Format:" VerticalAlignment="Top" Margin="0,12,0,5"/>
                                        <Grid Grid.Row="1" Grid.Column="1" Margin="5,8,5,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Shaded Views:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="img_shaded_format" Height="26" SelectedIndex="0">
                                                <ComboBoxItem Content="PNG"/>
                                                <ComboBoxItem Content="JPEG"/>
                                            </ComboBox>
                                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Non-Shaded Views:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <ComboBox Grid.Row="0" Grid.Column="4" x:Name="img_nonshaded_format" Height="26" SelectedIndex="0">
                                                <ComboBoxItem Content="PNG"/>
                                                <ComboBoxItem Content="JPEG"/>
                                            </ComboBox>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Raster Quality:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="img_dpi" Height="26" SelectedIndex="2">
                                                <ComboBoxItem Content="72 DPI"/><ComboBoxItem Content="96 DPI"/>
                                                <ComboBoxItem Content="150 DPI"/><ComboBoxItem Content="300 DPI"/>
                                                <ComboBoxItem Content="600 DPI"/>
                                            </ComboBox>
                                        </Grid>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="File:" VerticalAlignment="Top" Margin="0,12,0,5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="5,10,5,0">
                                            <RadioButton x:Name="img_separate_files" Content="Create separate images" GroupName="imgFile"
                                                         IsChecked="True" Margin="0,3"/>
                                            <RadioButton x:Name="img_combined_html" Content="Combine into single HTML file" GroupName="imgFile"
                                                         Margin="0,3"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Queue Tab -->
            <!-- Queue + Settings (combined) -->
            <TabItem Header="Queue" Style="{StaticResource TabItemStyle}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ── SETTINGS CARD ── -->
                    <Border Grid.Row="0" BorderBrush="#546E7A" BorderThickness="1"
                            Padding="12,10" Background="#F8F9FA" CornerRadius="3" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Output Folder -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Output Folder:" VerticalAlignment="Center"
                                           FontWeight="Medium" FontSize="12"/>
                                <TextBox x:Name="output_folder" Grid.Column="1" Height="26"
                                         VerticalContentAlignment="Center" Margin="5,0" Background="White"/>
                                <Button Grid.Column="2" Content="Browse..." Height="26"
                                        Style="{StaticResource SecondaryButton}" Click="browse_output_folder"/>
                            </Grid>

                            <!-- Organize + Reverse on one row -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Organize:" VerticalAlignment="Center"
                                           FontWeight="Medium" FontSize="12" Margin="0,0,8,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton x:Name="save_same_folder" Content="Same folder"
                                                 GroupName="organization" IsChecked="True" Margin="0,0,12,0"/>
                                    <RadioButton x:Name="save_split_by_format" Content="Split by format"
                                                 GroupName="organization"/>
                                </StackPanel>

                                <CheckBox x:Name="reverse_order" Grid.Column="3" Content="Reverse order"
                                          VerticalAlignment="Center"
                                          Checked="reverse_order_changed" Unchecked="reverse_order_changed"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── QUEUE SECTION ── -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Export Queue" Style="{StaticResource SectionHeader}"/>

                        <Border Grid.Row="1" BorderBrush="#546E7A" BorderThickness="1" Margin="0,5" CornerRadius="3">
                            <ListView x:Name="export_preview_list"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Sheet Number" Width="250"
                                                        DisplayMemberBinding="{Binding SheetNumber}"/>
                                        <GridViewColumn Header="Sheet Name" Width="280"
                                                        DisplayMemberBinding="{Binding SheetName}"/>
                                        <GridViewColumn Header="Format" Width="80"
                                                        DisplayMemberBinding="{Binding Format}"/>
                                        <GridViewColumn Header="Size" Width="80"
                                                        DisplayMemberBinding="{Binding Size}"/>
                                        <GridViewColumn Header="Orientation" Width="90"
                                                        DisplayMemberBinding="{Binding Orientation}"/>
                                        <GridViewColumn Header="Progress" Width="240">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <ProgressBar Grid.Row="0" Value="{Binding Progress}" Height="18" Minimum="0" Maximum="100" Margin="0,0,0,2">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Progress}" Value="100">
                                                                            <Setter Property="Foreground" Value="#27AE60"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                        <TextBlock Grid.Row="1" Text="{Binding Status}" FontSize="11" Foreground="#27AE60" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,2,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>

                        <StackPanel Grid.Row="2" Margin="0,8,0,0">
                            <TextBlock x:Name="progress_text" Text="Ready to export"
                                       FontSize="12" Foreground="#7F8C8D"/>
                            <ProgressBar x:Name="overall_progress" Height="20" Minimum="0" Maximum="100"
                                         Value="0" Margin="0,5"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
                </TabControl>
            </Grid>

        </Grid>

        <!-- ═══════════════ ACTION BAR (Row 3) ═══════════════ -->
        <Border Grid.Row="3" Background="White" BorderBrush="#546E7A" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="status_text" Text="Ready | 0 sheets | Revit" FontStyle="Italic" FontSize="12" Foreground="#083D56"/>
                </StackPanel>

                <Button x:Name="back_button" Grid.Column="1"
                        Content="Back"
                        Style="{StaticResource SecondaryButton}"
                        Click="go_back"
                        Margin="0,0,10,0"
                        Width="100"
                        Visibility="Collapsed"/>

                <Button x:Name="next_button" Grid.Column="2"
                        Style="{StaticResource PrimaryButton}"
                        Click="go_next"
                        Width="100"
                        Background="#083D56">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="next_button_text" Text="Next" FontWeight="Medium"/>
                        <TextBlock x:Name="next_button_icon" Text="→" FontFamily="Inter" FontWeight="Medium" Margin="5,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════ NAVIGATION BAR (Row 1) ═══════════════ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#546E7A" BorderThickness="0,0,0,1" Height="60">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 1. Selection -->
                <Border x:Name="nav_border_selection" Grid.Column="0" Background="#F8F9FA" Margin="0" Cursor="Hand" MouseLeftButtonDown="nav_item_clicked">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="nav_icon_selection" Text="&#xE14C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#083D56" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock x:Name="nav_text_selection" Text="Selection" FontSize="10" Foreground="#083D56" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 2. Format -->
                <Border x:Name="nav_border_format" Grid.Column="1" Background="Transparent" Margin="0" Cursor="Hand" MouseLeftButtonDown="nav_item_clicked">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="nav_icon_format" Text="&#xE1DC;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock x:Name="nav_text_format" Text="Format" FontSize="10" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 3. Queue + Settings -->
                <Border x:Name="nav_border_queue" Grid.Column="2" Background="Transparent" Margin="0" Cursor="Hand" MouseLeftButtonDown="nav_item_clicked">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="nav_icon_queue" Text="&#xE914;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock x:Name="nav_text_queue" Text="Queue" FontSize="10" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Copyright added automatically -->
        <TextBlock Text="© Copyright by T3Lab" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,8" Foreground="#3498DB" FontSize="11" IsHitTestVisible="False" Panel.ZIndex="999"/>
    </Grid>
</Window>
