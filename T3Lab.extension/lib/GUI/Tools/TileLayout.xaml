<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tile Layout"
        Width="860" Height="780"
        MinWidth="760" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="White"
        FontFamily="Inter">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#083D56"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#062A3C"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#546E7A"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E6EA"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#546E7A"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#546E7A"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,14,0,8"/>
        </Style>

        <Style x:Key="StepCircle" TargetType="Border">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#546E7A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,18,0"/>
        </Style>

        <Style x:Key="HiddenTab" TargetType="TabItem">
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>  <!-- Title bar -->
            <RowDefinition Height="52"/>  <!-- Step progress -->
            <RowDefinition Height="*"/>   <!-- Content -->
            <RowDefinition Height="64"/>  <!-- Action bar -->
            <RowDefinition Height="40"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ TITLE BAR ═══════════════ -->
        <Grid Grid.Row="0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical"
                        Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#083D56" VerticalAlignment="Bottom" Margin="0,0,6,3"/>
                    <TextBlock Text="Tile Layout" FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                </StackPanel>
                <Separator Height="1" Background="#546E7A" Margin="0,2,0,2"/>
                <TextBlock Text="Best-fit tiling options with off-cut nesting"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Top" Margin="0,0,4,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_minimize" Style="{StaticResource WinCtrlButton}"
                        ToolTip="Minimize" Click="minimize_button_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>
                <Button x:Name="btn_maximize" Style="{StaticResource WinCtrlButton}"
                        ToolTip="Maximize" Click="maximize_button_clicked">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>
                <Button x:Name="btn_close" Style="{StaticResource CloseButton}"
                        ToolTip="Close" Click="close_button_clicked">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══════════════ STEP PROGRESS ═══════════════ -->
        <Border Grid.Row="1" Background="#F8F9FA"
                BorderBrush="#546E7A" BorderThickness="0,1,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal">
                    <Border x:Name="step1_circle" Style="{StaticResource StepCircle}">
                        <TextBlock x:Name="step1_num" Text="1" Foreground="White"
                                   FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="step1_label" Text="Boundaries" Style="{StaticResource StepLabel}"/>
                </StackPanel>

                <TextBlock Text="→" Foreground="#546E7A" VerticalAlignment="Center"
                           Margin="0,0,18,0" FontSize="14"/>

                <StackPanel Orientation="Horizontal">
                    <Border x:Name="step2_circle" Style="{StaticResource StepCircle}">
                        <TextBlock x:Name="step2_num" Text="2" Foreground="White"
                                   FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="step2_label" Text="Pattern" Style="{StaticResource StepLabel}"/>
                </StackPanel>

                <TextBlock Text="→" Foreground="#546E7A" VerticalAlignment="Center"
                           Margin="0,0,18,0" FontSize="14"/>

                <StackPanel Orientation="Horizontal">
                    <Border x:Name="step3_circle" Style="{StaticResource StepCircle}">
                        <TextBlock x:Name="step3_num" Text="3" Foreground="White"
                                   FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="step3_label" Text="Concepts" Style="{StaticResource StepLabel}"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ═══════════════ CONTENT (3 steps) ═══════════════ -->
        <TabControl Grid.Row="2" x:Name="wizard_tabs"
                    BorderThickness="0" Background="White"
                    Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource HiddenTab}"/>
            </TabControl.Resources>

            <!-- ─── STEP 1: Boundaries ─── -->
            <TabItem>
                <Grid Margin="28,18,28,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Step 1 — Extract Floor Boundaries"
                               FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50"
                               Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1"
                               Text="Pick one or more floors. The tool will read each top face and show its dimensions."
                               FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,18"
                               TextWrapping="Wrap"/>

                    <Border Grid.Row="2" BorderBrush="#546E7A" BorderThickness="1"
                            CornerRadius="4" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="#F8F9FA"
                                    BorderBrush="#546E7A" BorderThickness="0,0,0,1"
                                    Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="floors_count_text"
                                                   Text="No floors selected yet"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#2C3E50"/>
                                        <TextBlock x:Name="floors_total_text"
                                                   Text=""
                                                   FontSize="11" Foreground="#7F8C8D"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" x:Name="btn_select"
                                            Style="{StaticResource PrimaryButton}"
                                            Content="Pick Floors in Model"
                                            Click="select_floors_clicked"/>
                                </Grid>
                            </Border>

                            <ListView Grid.Row="1" x:Name="floors_listview"
                                      BorderThickness="0" Background="White"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.View>
                                    <GridView>
                                        <GridView.ColumnHeaderContainerStyle>
                                            <Style TargetType="GridViewColumnHeader">
                                                <Setter Property="Background" Value="#F8F9FA"/>
                                                <Setter Property="Foreground" Value="#2C3E50"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="Padding" Value="10,6"/>
                                            </Style>
                                        </GridView.ColumnHeaderContainerStyle>
                                        <GridViewColumn Header="Floor" Width="260"
                                                        DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="Level" Width="120"
                                                        DisplayMemberBinding="{Binding LevelName}"/>
                                        <GridViewColumn Header="Dimensions (mm)" Width="160"
                                                        DisplayMemberBinding="{Binding Dimensions}"/>
                                        <GridViewColumn Header="Area (m²)" Width="100"
                                                        DisplayMemberBinding="{Binding AreaM2}"/>
                                        <GridViewColumn Header="Vertices" Width="80"
                                                        DisplayMemberBinding="{Binding VertexCount}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ─── STEP 2: Pattern ─── -->
            <TabItem>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,18,28,8">
                    <StackPanel>

                        <TextBlock Text="Step 2 — Choose Tile Pattern per Floor"
                                   FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Set tile size + grout globally, then pick a pattern per floor."
                                   FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,14"
                                   TextWrapping="Wrap"/>

                        <!-- Global tile size -->
                        <TextBlock Text="TILE DIMENSIONS (applied to all floors)"
                                   Style="{StaticResource SectionHeader}"/>
                        <Border Background="#F8F9FA" BorderBrush="#546E7A" BorderThickness="1"
                                CornerRadius="4" Padding="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (mm)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox  Grid.Row="2" Grid.Column="0" x:Name="txt_tile_w"
                                          Style="{StaticResource InputBox}" Text="600"/>

                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Height (mm)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox  Grid.Row="2" Grid.Column="2" x:Name="txt_tile_h"
                                          Style="{StaticResource InputBox}" Text="600"/>

                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Joint / Grout (mm)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox  Grid.Row="2" Grid.Column="4" x:Name="txt_joint"
                                          Style="{StaticResource InputBox}" Text="3"/>

                                <CheckBox Grid.Row="2" Grid.Column="6" x:Name="chk_nesting"
                                          IsChecked="True" FontSize="12"
                                          Foreground="#2C3E50" VerticalAlignment="Center"
                                          Content="Optimize off-cuts"/>
                            </Grid>
                        </Border>

                        <!-- Per-floor pattern (rows built programmatically) -->
                        <TextBlock Text="PATTERN PER FLOOR" Style="{StaticResource SectionHeader}"/>
                        <Border BorderBrush="#546E7A" BorderThickness="1" CornerRadius="4">
                            <StackPanel x:Name="pattern_stack"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ─── STEP 3: Concepts ─── -->
            <TabItem>
                <Grid Margin="28,18,28,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Step 3 — Pick the Best Layout for Each Floor"
                               FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50"
                               Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="1"
                               Text="Each floor got several candidate layouts (rotated / shifted variants). Click a card to select — Ctrl+Wheel zooms the preview, right-drag pans, right-double-click resets. Then Apply to materialize."
                               FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,14"
                               TextWrapping="Wrap"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="concepts_host"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ═══════════════ ACTION BAR ═══════════════ -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="#546E7A" BorderThickness="0,1,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="btn_back"
                        Style="{StaticResource SecondaryButton}"
                        Content="← Back" Width="100"
                        IsEnabled="False"
                        Click="back_clicked"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="2" x:Name="btn_export_report"
                        Style="{StaticResource SecondaryButton}"
                        Content="Export PDF Report" Width="150"
                        IsEnabled="False"
                        ToolTip="Print a multi-page report with every option for every floor. Choose 'Microsoft Print to PDF' to save as a PDF file."
                        Click="export_report_clicked"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="4" x:Name="btn_export"
                        Style="{StaticResource SecondaryButton}"
                        Content="Export CSV" Width="120"
                        IsEnabled="False"
                        Click="export_csv_clicked"
                        VerticalAlignment="Center"/>

                <Button Grid.Column="6" x:Name="btn_next"
                        Style="{StaticResource SuccessButton}"
                        Content="Next →" Width="160"
                        IsEnabled="False"
                        Click="next_clicked"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════ STATUS BAR ═══════════════ -->
        <Border Grid.Row="4" Background="#F8F9FA"
                BorderBrush="#546E7A" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <TextBlock x:Name="status_text"
                           Text="Ready — start by picking floors."
                           FontSize="12" Foreground="#7F8C8D"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    
        <!-- Copyright added automatically -->
        <TextBlock Text="© Copyright by T3Lab" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,8" Foreground="#3498DB" FontSize="11" IsHitTestVisible="False" Panel.ZIndex="999"/>
    </Grid>
</Window>
