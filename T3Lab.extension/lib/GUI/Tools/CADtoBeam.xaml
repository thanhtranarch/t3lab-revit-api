<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revit Beam From CAD"
        Width="450" Height="580"
        Background="White"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Section Header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin"     Value="0,14,0,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#3498DB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Close Button -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E74C3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0" Background="White">
            <StackPanel Orientation="Vertical" Margin="20,0,0,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,6,0"/>
                    <TextBlock Text="Beam From CAD" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
                <TextBlock Text="Auto-pairing parallel lines and type creation" FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_close" Style="{StaticResource WinCtrlButton}" Click="close_button_clicked">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
            <Border Height="1" VerticalAlignment="Bottom" Background="#BDC3C7"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,10,20,20">
                
                <!-- CAD Link -->
                <TextBlock Text="SELECT CAD FILE (Import/Link)" Style="{StaticResource SectionHeader}"/>
                <ComboBox x:Name="cb_cad_links" Height="30" VerticalContentAlignment="Center" SelectionChanged="cad_link_changed"/>

                <!-- Layer -->
                <TextBlock Text="BEAM OUTLINE LAYER" Style="{StaticResource SectionHeader}"/>
                <ComboBox x:Name="cb_layers" Height="30" VerticalContentAlignment="Center"/>

                <!-- Family -->
                <TextBlock Text="BEAM FAMILY (M_Concrete-Rectangular Beam)" Style="{StaticResource SectionHeader}"/>
                <ComboBox x:Name="cb_beam_types" Height="30" VerticalContentAlignment="Center"/>

                <!-- Level -->
                <TextBlock Text="PLACEMENT LEVEL" Style="{StaticResource SectionHeader}"/>
                <ComboBox x:Name="cb_levels" Height="30" VerticalContentAlignment="Center"/>

                <!-- Settings -->
                <TextBlock Text="PLACEMENT SETTINGS" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Margin="0,0,5,0">
                        <TextBlock Text="Default Z Offset (mm)" FontSize="10" Foreground="#7F8C8D"/>
                        <TextBox x:Name="txt_offset" Text="-50" Height="26" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Auto-Pairing Mode" FontSize="10" Foreground="#7F8C8D"/>
                        <CheckBox Content="Active" IsChecked="True" IsEnabled="False" VerticalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="WORKFLOW: The tool pairs parallel lines in the selected layer, calculates centerlines, and automatically creates beam types (e.g., 200x500) based on detected widths." 
                           FontSize="9" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,15,0,0"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="20,0,20,20">
            <Button x:Name="btn_generate" Content="START MODELING BEAMS" Style="{StaticResource PrimaryButton}" Click="generate_clicked"/>
        </Border>
    </Grid>
</Window>
