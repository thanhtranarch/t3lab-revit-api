        <!-- ── Window control buttons ── -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Close button (red on hover) ── -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Attachment chip button ── -->
        <Style x:Key="AttachChipBtn" TargetType="Button">
            <Setter Property="Background"      Value="#EBF5FB"/>
            <Setter Property="Foreground"      Value="#2980B9"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#E8F4F8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#E8F4F8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3498DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon-only button (attach) ── -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EBF5FB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- Header   -->
            <RowDefinition Height="1"/>    <!-- Separator -->
            <RowDefinition Height="*"/>    <!-- Chat area -->
            <RowDefinition Height="Auto"/> <!-- Input bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             HEADER — T3Lab badge + title
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <StackPanel Grid.Column="0" Orientation="Vertical"
                        Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#3498DB" VerticalAlignment="Bottom"
                               Margin="0,0,6,3"/>
                    <TextBlock Text="Assistant" FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                    <!-- AI / LOCAL status badge -->
                    <Border x:Name="ai_status_badge"
                            CornerRadius="3" Padding="5,2"
                            Margin="8,2,0,0" VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ai_status_text"
                                   FontSize="9" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
                <Separator Height="1" Background="#BDC3C7" Margin="0,2,0,2"/>
                <TextBlock Text="Chatbox AI cho T3Lab Tools — Tiếng Việt &amp; English"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <!-- Window control buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Top" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <!-- Undo -->
                <Button x:Name="btn_undo"
                        Style="{StaticResource WindowControlButton}"
                        ToolTip="Hoàn tác (Undo)"
                        Click="undo_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="↶" FontSize="18" FontWeight="Bold" Foreground="#E67E22"/>
                </Button>
                <!-- Reset -->
                <Button x:Name="btn_reset_chat"
                        Style="{StaticResource WindowControlButton}"
                        ToolTip="Làm mới cuộc trò chuyện"
                        Click="reset_chat_clicked"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="↺" FontSize="15" FontWeight="Bold" Foreground="#7F8C8D"/>
                </Button>
                <!-- Minimize -->
                <Button x:Name="btn_minimize"
                        Style="{StaticResource WindowControlButton}"
                        ToolTip="Minimize" Click="minimize_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>
                <!-- Close -->
                <Button x:Name="btn_close"
                        Style="{StaticResource CloseButton}"
                        ToolTip="Close" Click="close_clicked">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Header separator -->
        <Border Grid.Row="1" Background="#E0E0E0"/>

        <!-- ═══════════════════════════════════════════════════════════
             CHAT AREA
        ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" x:Name="chat_scroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#F4F6F7"
                      Padding="14,12,14,8">
            <StackPanel x:Name="chat_history_panel" Margin="0,0,0,4">

                <!-- Welcome bubble (static, always shown) -->
                <Grid Margin="0,0,60,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- T3 Avatar -->
                    <Border Grid.Column="0" Width="34" Height="34"
                            CornerRadius="17" Background="#3498DB"
                            Margin="0,2,10,0" VerticalAlignment="Top">
                        <TextBlock Text="T3" FontSize="11" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Welcome message bubble -->
                    <Border Grid.Column="1" Background="White"
                            CornerRadius="3,10,10,10"
                            Padding="14,10"
                            BorderBrush="#ECF0F1" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="T3Lab Assistant" FontSize="10" FontWeight="Bold"
                                       Foreground="#3498DB" Margin="0,0,0,5"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#2C3E50"
                                       LineHeight="20"
                                       Text="Xin chào! Tôi là T3Lab Assistant. Tôi có thể:"/>
                            <StackPanel Margin="0,6,0,0">
                                <TextBlock FontSize="12" Foreground="#7F8C8D"
                                           Text="• Mở BatchOut và xuất sheet PDF/DWG/DWF..."/>
                                <TextBlock FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"
                                           Text="• Chạy ParaSync, Load Family, và các công cụ khác"/>
                                <TextBlock FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"
                                           Text="• Phân tích tài liệu PDF và hình ảnh đính kèm (RAG)"/>
                                <TextBlock FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"
                                           Text="• Trả lời câu hỏi về T3Lab và Revit"/>
                            </StackPanel>
                            <Separator Height="1" Background="#ECF0F1" Margin="0,8,0,6"/>
                            <TextBlock FontSize="11" Foreground="#95A5A6" FontStyle="Italic"
                                       Text="Nhập lệnh bằng Tiếng Việt hoặc English — Enter để gửi. 📎 để đính kèm PDF/ảnh."/>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════
             INPUT BAR & ACTION CENTER
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="#ECF0F1" BorderThickness="0,1,0,0"
                Padding="14,8,14,10">
            <StackPanel>
                
                <!-- ── Suggested Actions Panel ── -->
                <StackPanel x:Name="suggested_actions_container" Margin="0,0,0,8">
                    <TextBlock Text="Suggested Actions" FontSize="10" FontWeight="SemiBold" 
                               Foreground="#7F8C8D" Margin="4,0,0,4"/>
                    <WrapPanel x:Name="suggested_actions_panel">
                        <!-- Chips will be added dynamically -->
                    </WrapPanel>
                </StackPanel>

                <!-- ── Attachment preview strip (hidden until files attached) ── -->
                <Border x:Name="attachment_preview_border"
                        Visibility="Collapsed"
                        Background="#F0F8FF"
                        BorderBrush="#E8F4F8" BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,6"
                        Margin="0,0,0,6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="&#x1F4CE; Đính kèm:" FontSize="10" FontWeight="Bold"
                                       Foreground="#2980B9" VerticalAlignment="Center"/>
                            <Button x:Name="btn_clear_attachments"
                                    Style="{StaticResource IconButton}"
                                    Click="clear_attachments_clicked"
                                    ToolTip="Xóa tất cả đính kèm"
                                    Margin="6,0,0,0"
                                    Padding="3,1">
                                <TextBlock Text="✕ Xóa tất cả" FontSize="9" Foreground="#E74C3C"/>
                            </Button>
                        </StackPanel>
                        <WrapPanel x:Name="attachment_chips_panel"/>
                    </StackPanel>
                </Border>

                <!-- ── Input row ── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- Attach button -->
                        <ColumnDefinition Width="*"/>     <!-- Text input -->
                        <ColumnDefinition Width="Auto"/>  <!-- Send button -->
                    </Grid.ColumnDefinitions>

                    <!-- Attach button -->
                    <Button Grid.Column="0" x:Name="btn_attach"
                             Style="{StaticResource IconButton}"
                             Height="38" Width="38"
                             Click="attach_clicked"
                             ToolTip="Đính kèm hình ảnh hoặc PDF">
                        <TextBlock Text="📎" FontSize="16" VerticalAlignment="Center"
                                    HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Text input -->
                    <Border Grid.Column="1"
                            BorderBrush="#BDC3C7" BorderThickness="1,1,0,1"
                            CornerRadius="20,0,0,20" Background="White">
                        <TextBox x:Name="chat_input"
                                  Height="38"
                                  VerticalContentAlignment="Center"
                                  Padding="14,0"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  FontSize="13"
                                  Foreground="#2C3E50"
                                  CaretBrush="#3498DB"
                                  ToolTip="Nhập lệnh Tiếng Việt hoặc English (Enter để gửi)"
                                  KeyDown="input_keydown"/>
                    </Border>

                    <!-- Send button -->
                    <Button Grid.Column="2" x:Name="send_button"
                             Height="38"
                             Style="{StaticResource SendButtonStyle}"
                             Padding="18,0"
                             Click="send_clicked"
                             ToolTip="Gửi (Enter)">

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Gửi" VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock Text=" ➤" FontSize="11" VerticalAlignment="Center"
                                            Margin="2,0,0,0"/>
                            </StackPanel>

                    </Button>
                </Grid>

                <!-- Copyright -->
                <TextBlock Text="© Copyright by T3Lab"
                            FontSize="10" Foreground="#BDC3C7"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
