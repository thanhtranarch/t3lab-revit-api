<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Location Manager - T3Lab"
        Width="1080" Height="700"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="White"
        FontFamily="Inter"
        FontSize="12">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#083D56"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Inter"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#062A3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#546E7A"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Inter"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E6EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Inter"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B71C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Source-mode toggle: RadioButton styled as a segment button -->
        <Style x:Key="ModeRadioButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Inter"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="txt" Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#083D56"/>
                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#E2E6EA"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#062A3C"/>
                                <Setter TargetName="txt" Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Removes the default blue highlight on ListBoxItem so checkboxes look clean -->
        <Style x:Key="CategoryListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════ TITLE BAR ══════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="White" Height="64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#083D56" VerticalAlignment="Bottom" Margin="0,0,6,3"/>
                    <TextBlock Text="Location Manager" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>
                <Separator Height="1" Background="#546E7A" Margin="0,2,0,2"/>
                <TextBlock Text="Review and adjust element positions in the current view"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Top" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_minimize" Style="{StaticResource WinCtrlButton}"
                        ToolTip="Minimize" Click="minimize_button_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>
                <Button x:Name="btn_maximize" Style="{StaticResource WinCtrlButton}"
                        ToolTip="Maximize" Click="maximize_button_clicked">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56"/>
                </Button>
                <Button x:Name="btn_close" Style="{StaticResource CloseButton}"
                        ToolTip="Close" Click="close_button_clicked">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#083D56">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>

            <Border Height="1" VerticalAlignment="Bottom" Background="#546E7A" Grid.ColumnSpan="3"/>
        </Grid>

        <!-- ══════════════════════════════════════ TOOLBAR ══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#546E7A" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel VerticalAlignment="Center">
                    <!-- Source mode toggle -->
                    <Border BorderBrush="#546E7A" BorderThickness="1" CornerRadius="3"
                            Height="28" Margin="0,0,6,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="rb_current_view" Content="Current View"
                                         IsChecked="True" GroupName="SourceMode"
                                         Style="{StaticResource ModeRadioButton}"
                                         Checked="mode_changed"
                                         ToolTip="Load all elements from the active view"/>
                            <Border Width="1" Background="#546E7A"/>
                            <RadioButton x:Name="rb_by_level" Content="By Level"
                                         GroupName="SourceMode"
                                         Style="{StaticResource ModeRadioButton}"
                                         Checked="mode_changed"
                                         ToolTip="Load all elements assigned to a chosen level"/>
                        </StackPanel>
                    </Border>
                    <!-- Level picker — visible only in By Level mode -->
                    <ComboBox x:Name="cmb_level"
                              DisplayMemberPath="Name"
                              Height="28" Width="160"
                              Visibility="Collapsed"
                              VerticalContentAlignment="Center" Padding="6,2"
                              BorderBrush="#546E7A" BorderThickness="1"
                              Margin="0,0,6,0"
                              SelectionChanged="level_selection_changed"
                              ToolTip="Select a level to load elements from"/>
                    <Rectangle Width="1" Fill="#546E7A" Margin="0,2,8,2"/>
                    <Button x:Name="btn_refresh" Content="Refresh"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                            Click="refresh_clicked" ToolTip="Reload elements for the current source mode"/>
                    <Button x:Name="btn_get_sel" Content="Get Selection"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                            Click="get_selection_clicked" ToolTip="Load currently selected elements"/>
                    <Button x:Name="btn_pick" Content="Pick Elements"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                            Click="pick_elements_clicked" ToolTip="Pick elements directly from Revit canvas"/>
                    <Button x:Name="btn_sync_sel" Content="Sync Selection"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                            Click="sync_selection_clicked" ToolTip="Select highlighted rows in Revit"/>
                    <Rectangle Width="1" Fill="#546E7A" Margin="6,2,8,2"/>
                    <Button x:Name="btn_round_5mm" Content="Round 5mm"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            Click="round_to_5mm_clicked"
                            ToolTip="Round X, Y, Z coordinates to nearest 5mm (affects selected rows, or all if none selected)"/>
                    <Button x:Name="btn_override_odd" Content="Override Odd"
                            Style="{StaticResource DangerButton}" Margin="0,0,6,0"
                            Click="override_odd_clicked"
                            ToolTip="Highlight elements with non-integer mm coordinates — red cut/surface fill in active view"/>
                    <Button x:Name="btn_clear_override" Content="Clear Override"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                            Click="clear_overrides_clicked"
                            ToolTip="Remove graphic overrides from all loaded elements in active view"/>
                    <Rectangle Width="1" Fill="#546E7A" Margin="6,2,12,2"/>
                    <TextBlock Text="Search:" VerticalAlignment="Center" Foreground="#7F8C8D" Margin="0,0,6,0"/>
                    <TextBox x:Name="txt_search" Width="200" Height="28"
                             VerticalContentAlignment="Center" Padding="6,2"
                             BorderBrush="#546E7A" BorderThickness="1"
                             TextChanged="search_changed"
                             ToolTip="Filter by category, type, level or element ID"/>
                </WrapPanel>

                <Button Grid.Column="1" x:Name="btn_apply" Content="Apply Changes"
                        Style="{StaticResource SuccessButton}"
                        Click="apply_clicked" ToolTip="Move elements to edited coordinates"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════ CONTENT ══════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="130" MaxWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Category Filter Panel ── -->
            <Border Grid.Column="0" Background="White" BorderBrush="#546E7A" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#546E7A"
                            BorderThickness="0,0,0,1" Padding="10,8">
                        <TextBlock Text="CATEGORIES" FontSize="10" FontWeight="SemiBold" Foreground="#546E7A"/>
                    </Border>

                    <!-- All / None buttons -->
                    <Border Grid.Row="1" Padding="8,6" BorderBrush="#546E7A" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btn_select_all_cats" Content="All"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11"
                                    Click="select_all_categories_clicked"
                                    ToolTip="Show all categories"/>
                            <Button x:Name="btn_clear_cats" Content="None"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="10,4" FontSize="11" Margin="6,0,0,0"
                                    Click="clear_all_categories_clicked"
                                    ToolTip="Hide all categories"/>
                        </StackPanel>
                    </Border>

                    <!-- Category checklist -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="lst_categories"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource CategoryListItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,3">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8F9FA"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <CheckBox IsChecked="{Binding IsChecked}"
                                                  Click="category_filter_changed"
                                                  Cursor="Hand" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="11" Foreground="#2C3E50"
                                                           VerticalAlignment="Center"
                                                           MaxWidth="120"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Name}"/>
                                                <TextBlock Text="{Binding CountText}"
                                                           FontSize="10" Foreground="#7F8C8D"
                                                           Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── SPLITTER ── -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="#E2E6EA" Cursor="SizeWE"/>

            <!-- ── RIGHT: DataGrid ── -->
            <Grid Grid.Column="2" Margin="0,8,12,8">
                <DataGrid x:Name="elem_datagrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Extended"
                          IsReadOnly="False"
                          SelectionChanged="datagrid_selection_changed"
                          Background="White"
                          BorderBrush="#546E7A"
                          BorderThickness="1"
                          AlternatingRowBackground="#F8F9FA"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F8F9FA">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="Foreground" Value="#2C3E50"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderBrush" Value="#546E7A"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Height" Value="34"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8F9FA"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E2E6EA"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="ID" Width="90" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="4">
                                        <Hyperlink Click="id_clicked">
                                            <Run Text="{Binding Id}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Category"  Binding="{Binding Category}" Width="130" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Type / Name" Binding="{Binding Type}"   Width="*"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="Level"     Binding="{Binding Level}"    Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="X (mm)"   Binding="{Binding X, StringFormat={}{0:F8}, Mode=TwoWay}" Width="110"/>
                        <DataGridTextColumn Header="Y (mm)"   Binding="{Binding Y, StringFormat={}{0:F8}, Mode=TwoWay}" Width="110"/>
                        <DataGridTextColumn Header="Z (mm)"   Binding="{Binding Z, StringFormat={}{0:F8}, Mode=TwoWay}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════ STATUS BAR ══════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="#546E7A"
                BorderThickness="0,1,0,0" Padding="14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="status_text" FontSize="11" Foreground="#7F8C8D" Text="Ready"/>
                <TextBlock Grid.Column="1" x:Name="status_count" FontSize="11" Foreground="#546E7A"
                           HorizontalAlignment="Right" Text="0 elements"/>
            </Grid>
        </Border>

        <TextBlock Text="© Copyright by T3Lab" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,14,8" Foreground="#3498DB" FontSize="11" IsHitTestVisible="False" Panel.ZIndex="999"/>
    </Grid>
</Window>
