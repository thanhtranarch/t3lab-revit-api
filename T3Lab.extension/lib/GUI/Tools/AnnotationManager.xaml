<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       Title="Annotation Manager - T3Lab"
       Width="800" Height="680"
       MinWidth="700" MinHeight="560"
       WindowStartupLocation="CenterScreen"
       ResizeMode="CanResizeWithGrip"
       ShowInTaskbar="True"
       Background="White">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OrangeButton" TargetType="Button">
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E67E22"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D5DBDB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="18,9"/>
        </Style>

        <!-- Window Control Button Style -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Row / Cell styles -->
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D6EAF8"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="White" Height="64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo and Title -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#3498DB" VerticalAlignment="Bottom" Margin="0,0,6,3"/>
                    <TextBlock Text="Annotation Manager" FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                </StackPanel>
                <Separator Height="1" Background="#BDC3C7" Margin="0,2,0,2"/>
                <TextBlock Text="Find · Edit · Delete · Auto-Rename dimensions and text notes"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <!-- Window Control Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_minimize" Style="{StaticResource WindowControlButton}"
                        ToolTip="Minimize" Click="minimize_button_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>
                <Button x:Name="btn_maximize" Style="{StaticResource WindowControlButton}"
                        ToolTip="Maximize" Click="maximize_button_clicked">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>
                <Button x:Name="btn_close" Style="{StaticResource CloseButton}"
                        ToolTip="Close" Click="close_button_clicked">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20,0,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tab Control -->
            <TabControl Grid.Row="0" x:Name="main_tabs">

                <!-- ═══ DIMENSION TAB ═══ -->
                <TabItem Header="📐  Dimension" Style="{StaticResource TabItemStyle}">
                    <Grid Margin="10,8,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tip box -->
                        <Border Grid.Row="0" BorderBrush="#3498DB" BorderThickness="1" Padding="10,7"
                                Background="#E8F4F8" CornerRadius="2" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💡 Tip:" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,5,0"/>
                                <TextBlock Foreground="#2C3E50"
                                           Text="Find Dimensions to jump/delete. Find Types to rename inline (double-click Name)."/>
                            </StackPanel>
                        </Border>

                        <!-- Sub-mode toggle -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton x:Name="rb_dim_inst" Content="Find Dimensions  (search instances)"
                                         IsChecked="True" Margin="0,0,24,0" FontSize="12"
                                         Foreground="#2C3E50" Checked="dim_submode"/>
                            <RadioButton x:Name="rb_dim_type" Content="Find Types  (rename inline)"
                                         FontSize="12" Foreground="#2C3E50" Checked="dim_submode"/>
                        </StackPanel>

                        <!-- Search row -->
                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="dim_lbl" Grid.Column="0" Text="Type name:" VerticalAlignment="Center"
                                       FontWeight="Medium" Foreground="#2C3E50" Margin="0,0,8,0"/>
                            <TextBox x:Name="dim_kw" Grid.Column="1" Height="30"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="#BDC3C7" BorderThickness="1" FontFamily="Consolas"/>
                            <Button Grid.Column="2" Content="Search" Height="30" Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryButton}" Click="dim_search"/>
                            <Button Grid.Column="3" Content="⟳ Refresh" Height="30" Margin="6,0,0,0"
                                    Style="{StaticResource SecondaryButton}" Click="dim_refresh"/>
                            <TextBlock x:Name="dim_count" Grid.Column="4"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontSize="11" Foreground="#7F8C8D"/>
                        </Grid>

                        <!-- Result DataGrid -->
                        <Border Grid.Row="3" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="3">
                            <DataGrid x:Name="dg_dim"
                                      AutoGenerateColumns="False"
                                      SelectionMode="Extended"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserSortColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#F8F9FA"
                                      RowBackground="White"
                                      RowHeight="26"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding [_id]}"  IsReadOnly="True" Visibility="Collapsed" Width="0"/>
                                    <DataGridTextColumn Binding="{Binding [_cat]}" IsReadOnly="True" Visibility="Collapsed" Width="0"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding [Name]}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Size" Binding="{Binding [Size]}" Width="80"
                                                        Visibility="Collapsed">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Font" Binding="{Binding [Font]}" Width="110"
                                                        Visibility="Collapsed">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Background" Binding="{Binding [Background]}" Width="90"
                                                        Visibility="Collapsed">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Color" Binding="{Binding [Color]}" Width="90"
                                                        Visibility="Collapsed">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="View / Details" Binding="{Binding [Details]}"
                                                        IsReadOnly="True" Width="220">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Foreground" Value="#7F8C8D"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,8">
                            <Button x:Name="btn_dim_jump" Content="Jump to View"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,6,0" Click="dim_jump"/>
                            <Button Content="Delete Selected" Style="{StaticResource DangerButton}"
                                    Margin="0,0,6,0" Click="dim_delete"/>
                            <Button Content="Select All" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0" Click="dim_select_all"/>
                            <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0" Click="dim_clear_sel"/>
                            <Button x:Name="btn_dim_apply" Content="✔ Apply Changes"
                                    Style="{StaticResource PrimaryButton}"
                                    Visibility="Collapsed"
                                    Click="dim_apply"/>
                        </StackPanel>

                        <!-- Rename section -->
                        <Border Grid.Row="5" Background="#F8F9FA" BorderBrush="#D5DBDB"
                                BorderThickness="1" CornerRadius="3" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto-Rename All Dimension Types"
                                               FontWeight="Bold" Foreground="#2C3E50" FontSize="12"/>
                                    <TextBlock FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,3,0,0"
                                               Text="Generates: LB_[discipline]_[size]_[font]_[bg]_[color]_[prefix]_[indicators]"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Rename All" Width="110"
                                        Style="{StaticResource OrangeButton}"
                                        Click="dim_rename_all" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ═══ TEXT NOTE TAB ═══ -->
                <TabItem Header="📝  Text Note" Style="{StaticResource TabItemStyle}">
                    <Grid Margin="10,8,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tip box -->
                        <Border Grid.Row="0" BorderBrush="#3498DB" BorderThickness="1" Padding="10,7"
                                Background="#E8F4F8" CornerRadius="2" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💡 Tip:" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,5,0"/>
                                <TextBlock Foreground="#2C3E50"
                                           Text="Double-click Name to edit inline. Notes → edit content. Types → edit type name."/>
                            </StackPanel>
                        </Border>

                        <!-- Sub-mode toggle -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton x:Name="rb_notes" Content="Find Notes  (search by content)"
                                         IsChecked="True" Margin="0,0,24,0" FontSize="12"
                                         Foreground="#2C3E50" Checked="txt_submode"/>
                            <RadioButton x:Name="rb_types" Content="Find Types  (search by type name)"
                                         FontSize="12" Foreground="#2C3E50" Checked="txt_submode"/>
                        </StackPanel>

                        <!-- Search row -->
                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txt_lbl" Grid.Column="0" Text="Content:"
                                       VerticalAlignment="Center" FontWeight="Medium"
                                       Foreground="#2C3E50" Margin="0,0,8,0"/>
                            <TextBox x:Name="txt_kw" Grid.Column="1" Height="30"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="#BDC3C7" BorderThickness="1" FontFamily="Consolas"/>
                            <Button Grid.Column="2" Content="Search" Height="30" Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryButton}" Click="txt_search"/>
                            <Button Grid.Column="3" Content="⟳ Refresh" Height="30" Margin="6,0,0,0"
                                    Style="{StaticResource SecondaryButton}" Click="txt_refresh"/>
                            <TextBlock x:Name="txt_count" Grid.Column="4"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontSize="11" Foreground="#7F8C8D"/>
                        </Grid>

                        <!-- Result DataGrid -->
                        <Border Grid.Row="3" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="3">
                            <DataGrid x:Name="dg_txt"
                                      AutoGenerateColumns="False"
                                      SelectionMode="Extended"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserSortColumns="True"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#F8F9FA"
                                      RowBackground="White"
                                      RowHeight="26"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding [_id]}"  IsReadOnly="True" Visibility="Collapsed" Width="0"/>
                                    <DataGridTextColumn Binding="{Binding [_cat]}" IsReadOnly="True" Visibility="Collapsed" Width="0"/>
                                    <DataGridTextColumn Header="Name / Content" Binding="{Binding [Name]}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Size" Binding="{Binding [Size]}" Width="80"
                                                        Visibility="Collapsed">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Font" Binding="{Binding [Font]}" Width="110"
                                                        Visibility="Collapsed">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Background" Binding="{Binding [Background]}" Width="90"
                                                        Visibility="Collapsed">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Color" Binding="{Binding [Color]}" Width="90"
                                                        Visibility="Collapsed">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily" Value="Consolas"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="View / Details" Binding="{Binding [Details]}"
                                                        IsReadOnly="True" Width="220">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="11"/>
                                                <Setter Property="Foreground" Value="#7F8C8D"/>
                                                <Setter Property="Padding" Value="6,3"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,8">
                            <Button x:Name="btn_txt_jump" Content="Jump to View"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,6,0" Click="txt_jump"/>
                            <Button Content="Delete Selected" Style="{StaticResource DangerButton}"
                                    Margin="0,0,6,0" Click="txt_delete"/>
                            <Button Content="Select All" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0" Click="txt_select_all"/>
                            <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,6,0" Click="txt_clear_sel"/>
                            <Button x:Name="btn_txt_apply" Content="✔ Apply Changes"
                                    Style="{StaticResource PrimaryButton}"
                                    Visibility="Collapsed"
                                    Click="txt_apply"/>
                        </StackPanel>

                        <!-- Rename section -->
                        <Border Grid.Row="5" Background="#F8F9FA" BorderBrush="#D5DBDB"
                                BorderThickness="1" CornerRadius="3" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto-Rename All Text Note Types"
                                               FontWeight="Bold" Foreground="#2C3E50" FontSize="12"/>
                                    <TextBlock FontSize="10" Foreground="#7F8C8D" TextWrapping="Wrap" Margin="0,3,0,0"
                                               Text="Generates: LB_[discipline]_[size]_[font]_[bg]_[factor]_[color]_[border]_[B/U/I]"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Rename All" Width="110"
                                        Style="{StaticResource OrangeButton}"
                                        Click="txt_rename_all" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- Status bar -->
            <Border Grid.Row="1" BorderBrush="#ECF0F1" BorderThickness="0,1,0,0" Padding="4,6,0,0">
                <TextBlock x:Name="status" FontSize="11" Foreground="#7F8C8D" Text="Ready."/>
            </Border>
        </Grid>
    </Grid>
</Window>
