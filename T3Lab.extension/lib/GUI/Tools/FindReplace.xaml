<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    Title="Views: Find and Replace"
    Height="310" Width="400"
    MinWidth="400" MinHeight="310"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResizeWithGrip"
    Background="White"
    FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64" UseAeroCaptionButtons="False" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Window control button -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D5DBDB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E74C3C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="1"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Brand -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#3498DB" VerticalAlignment="Bottom" Margin="0,0,6,3"/>
                    <TextBlock Text="Find and Replace" FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                </StackPanel>
                <Separator Height="1" Background="#BDC3C7" Margin="0,2,0,2"/>
                <TextBlock Text="Rename views and elements"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <!-- Window controls -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="btn_minimize" Content="&#x2212;" Style="{StaticResource WinCtrlButton}"
                        Click="minimize_button_clicked"/>
                <Button x:Name="btn_maximize" Content="&#x25A1;" Style="{StaticResource WinCtrlButton}"
                        Click="maximize_button_clicked"/>
                <Button x:Name="btn_close" Content="&#xE8BB;" Style="{StaticResource CloseButton}"
                        Click="button_close"/>
            </StackPanel>
        </Grid>

        <!-- SEPARATOR -->
        <Rectangle Grid.Row="1" Fill="#BDC3C7"/>

        <!-- CONTENT -->
        <StackPanel Grid.Row="2" Margin="16,12,16,12">
            <Label x:Name="UI_label" Content="ViewName"
                   Foreground="#7F8C8D" Padding="0,0,0,4"/>

            <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4"
                    Padding="12,10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Find:" Foreground="#2C3E50" Width="64" VerticalAlignment="Center"/>
                        <TextBox x:Name="input_find" Background="White" Foreground="#2C3E50"
                                 BorderBrush="#BDC3C7" BorderThickness="1" Padding="4,3"
                                 HorizontalAlignment="Stretch"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Replace:" Foreground="#2C3E50" Width="64" VerticalAlignment="Center"/>
                        <TextBox x:Name="input_replace" Background="White" Foreground="#2C3E50"
                                 BorderBrush="#BDC3C7" BorderThickness="1" Padding="4,3"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Prefix:" Foreground="#2C3E50" Width="64" VerticalAlignment="Center"/>
                        <TextBox x:Name="input_prefix" Background="White" Foreground="#2C3E50"
                                 BorderBrush="#BDC3C7" BorderThickness="1" Padding="4,3"/>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="Suffix:" Foreground="#2C3E50" Width="64" VerticalAlignment="Center"/>
                        <TextBox x:Name="input_suffix" Background="White" Foreground="#2C3E50"
                                 BorderBrush="#BDC3C7" BorderThickness="1" Padding="4,3"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <Button x:Name="UI_main_button" Content="Rename"
                    Style="{StaticResource PrimaryButton}"
                    Click="button_run" Margin="0,12,0,0"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>
</Window>
