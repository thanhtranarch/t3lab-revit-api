<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="T3Lab - Bulk Family Export"
        Width="1100" Height="680"
        MinWidth="860" MinHeight="500"
        Background="White"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- PRIMARY BUTTON - blue, white text -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#3498DB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Cursor"     Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SECONDARY BUTTON - light gray, dark text -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#ECF0F1"/>
            <Setter Property="Foreground"      Value="#2C3E50"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#BDC3C7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D5DBDB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SUCCESS BUTTON - green -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- WINDOW CONTROL BUTTON -->
        <Style x:Key="WinCtrlButton" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CLOSE BUTTON - red on hover -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WinCtrlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>       <!-- Title bar -->
            <RowDefinition Height="Auto"/>     <!-- Configuration -->
            <RowDefinition Height="Auto"/>     <!-- Info tip -->
            <RowDefinition Height="Auto"/>     <!-- Filter bar -->
            <RowDefinition Height="*"/>        <!-- DataGrid -->
            <RowDefinition Height="Auto"/>     <!-- Action bar -->
            <RowDefinition Height="Auto"/>     <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ TITLE BAR ═══ -->
        <Grid Grid.Row="0" Height="64" Background="White">
            <StackPanel Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold" Foreground="#3498DB"
                               VerticalAlignment="Bottom" Margin="0,0,6,3"/>
                    <TextBlock Text="Bulk Family Export" FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                </StackPanel>
                <Separator Height="1" Background="#BDC3C7" Margin="0,2,0,2"/>
                <TextBlock Text="Export CAD blocks or generate parametric Door/Window families"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_minimize" Style="{StaticResource WinCtrlButton}"
                        Click="minimize_button_clicked" ToolTip="Minimize">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>
                <Button x:Name="btn_maximize" Style="{StaticResource WinCtrlButton}"
                        Click="maximize_button_clicked" ToolTip="Maximize">
                    <TextBlock Text="&#x25A1;" FontSize="14" Foreground="#7F8C8D"/>
                </Button>
                <Button x:Name="btn_close" Style="{StaticResource CloseButton}"
                        Click="close_button_clicked" ToolTip="Close">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>
            </StackPanel>

            <Border Height="1" VerticalAlignment="Bottom" Background="#BDC3C7"/>
        </Grid>

        <!-- ═══ CONFIGURATION ═══ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- CAD Type -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="CAD Type:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <ComboBox x:Name="cad_file_combo" Grid.Row="0" Grid.Column="1"
                          FontFamily="Segoe UI" FontSize="12" Padding="6,4" Margin="0,0,8,0"/>
                <Button Content="Scan Blocks" Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource PrimaryButton}" Click="scan_blocks_clicked"/>

                <!-- Discipline -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Discipline:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <ComboBox x:Name="discipline_combo" Grid.Row="2" Grid.Column="1"
                          Grid.ColumnSpan="2" FontFamily="Segoe UI" FontSize="12" Padding="6,4"/>

                <!-- Category -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Category:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <ComboBox x:Name="category_combo" Grid.Row="4" Grid.Column="1"
                          Grid.ColumnSpan="2" FontFamily="Segoe UI" FontSize="12" Padding="6,4"/>

                <!-- Geometry Mode -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Geometry:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <StackPanel Orientation="Horizontal" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2">
                    <RadioButton x:Name="rb_3d_solid" Content=" 3D Solid / Extrusion" IsChecked="False"
                                 IsEnabled="False"
                                 VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#BDC3C7" FontFamily="Segoe UI" FontSize="12"
                                 ToolTip="3D Solid export — coming soon"/>
                    <RadioButton x:Name="rb_2d_lines" Content=" 2D Model Lines Only" IsChecked="True"
                                 VerticalAlignment="Center" Foreground="#2C3E50" FontFamily="Segoe UI" FontSize="12"/>
                </StackPanel>

                <!-- Output Folder -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Output:"
                           VerticalAlignment="Center" Foreground="#2C3E50" FontSize="12"/>
                <TextBox x:Name="output_path" Grid.Row="8" Grid.Column="1"
                         IsReadOnly="True" FontFamily="Segoe UI" FontSize="12"
                         Padding="6,4" Margin="0,0,8,0" Background="#F8F9FA"
                         BorderBrush="#BDC3C7"/>
                <Button Content="Browse..." Grid.Row="8" Grid.Column="2"
                        Style="{StaticResource SecondaryButton}" Click="browse_folder_clicked"/>
            </Grid>
        </Border>

        <!-- ═══ INFO TIP ═══ -->
        <Border Grid.Row="2" Margin="16,10,16,0" BorderBrush="#3498DB" BorderThickness="1"
                Background="#E8F4F8" CornerRadius="2" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Tip:" FontWeight="Bold" Foreground="#2980B9" Margin="0,0,5,0"/>
                <TextBlock Foreground="#2C3E50" TextWrapping="Wrap"
                           Text="CAD Mode: Select a CAD file and click 'Scan Blocks' — category is auto-detected per block and can be changed in the grid. Preset Mode: Select output folder and category, then click 'Presets' to generate families without any CAD file."/>
            </StackPanel>
        </Border>

        <!-- ═══ DATAGRID ═══ -->
        <!-- FILTER BAR -->
        <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="#BDC3C7"
                BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Search box -->
                <Border Grid.Column="0" BorderBrush="#BDC3C7" BorderThickness="1"
                        CornerRadius="3" Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="12"
                                   Foreground="#7F8C8D" VerticalAlignment="Center"
                                   Margin="8,0,4,0"/>
                        <TextBox x:Name="txt_search" Grid.Column="1"
                                 FontFamily="Segoe UI" FontSize="12"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalAlignment="Center" Padding="0,5"
                                 ToolTip="Search block name or layer"
                                 TextChanged="search_text_changed"/>
                        <TextBlock x:Name="txt_search_placeholder"
                                   Grid.Column="1" IsHitTestVisible="False"
                                   Text="Search block name or layer�"
                                   FontFamily="Segoe UI" FontSize="12"
                                   Foreground="#BDC3C7" VerticalAlignment="Center"
                                   Padding="2,5"/>
                        <Button x:Name="btn_clear_search" Grid.Column="2"
                                Content="&#xE8BB;" Width="24" Height="24"
                                Foreground="#7F8C8D" Background="Transparent"
                                BorderThickness="0" Cursor="Hand"
                                VerticalAlignment="Center" Margin="2,0"
                                Click="clear_search_clicked"
                                Visibility="Collapsed"
                                ToolTip="Clear search"/>
                    </Grid>
                </Border>
                <!-- Suggested filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Suggested:" FontFamily="Segoe UI" FontSize="12"
                               Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="combo_filter_suggested"
                              FontFamily="Segoe UI" FontSize="12" Padding="6,4"
                              Width="130"
                              SelectionChanged="filter_suggested_changed"
                              ToolTip="Filter by suggested category"/>
                </StackPanel>
                <!-- Visible count -->
                <TextBlock x:Name="txt_filter_count" Grid.Column="4"
                           FontFamily="Segoe UI" FontSize="11" Foreground="#7F8C8D"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- DATAGRID -->
        <DataGrid x:Name="blocks_grid" Grid.Row="4" Margin="16,6,16,0"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  Background="White" BorderBrush="#BDC3C7" BorderThickness="1"
                  AlternatingRowBackground="#F8F9FA" FontFamily="Segoe UI" FontSize="12"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#ECF0F1" SelectionMode="Single"
                  VerticalScrollBarVisibility="Auto">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"      Value="#ECF0F1"/>
                    <Setter Property="Foreground"      Value="#2C3E50"/>
                    <Setter Property="FontWeight"      Value="SemiBold"/>
                    <Setter Property="Padding"         Value="8,6"/>
                    <Setter Property="BorderBrush"     Value="#BDC3C7"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Height"          Value="34"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#EBF5FB"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#D6EAF8"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Select -->
                <DataGridTemplateColumn Header="&#x2713;" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Identity -->
                <DataGridTextColumn Header="Block Name"   Binding="{Binding BlockName}"    Width="*"   IsReadOnly="True"/>
                <DataGridTextColumn Header="Layer/Level"  Binding="{Binding LayerLevel}"   Width="110" IsReadOnly="True"/>

                <!-- Counts -->
                <DataGridTextColumn Header="Curves"    Binding="{Binding CurveCount}"    Width="60" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Instances" Binding="{Binding InstanceCount}" Width="70" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Category Details -->
                <DataGridTextColumn Header="Width (mm)" Binding="{Binding WidthMM}" Width="82" IsReadOnly="True">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/><Setter Property="Foreground" Value="#2C3E50"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Depth (mm)" Binding="{Binding DepthMM}" Width="82" IsReadOnly="True">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Padding" Value="0,0,8,0"/><Setter Property="Foreground" Value="#2C3E50"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Arcs" Binding="{Binding ArcCount}" Width="52" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Foreground" Value="#7F8C8D"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══ ACTION BAR ═══ -->
        <Border Grid.Row="5" Background="White" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Select All" Style="{StaticResource SecondaryButton}"
                            Click="select_all_clicked" Margin="0,0,8,0"/>
                    <Button Content="Deselect All" Style="{StaticResource SecondaryButton}"
                            Click="deselect_all_clicked"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <CheckBox x:Name="chk_load_to_project"
                              Content="Load to Project"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0"
                              Foreground="#2C3E50"
                              FontFamily="Segoe UI"
                              FontSize="12"
                              ToolTip="After export, load each family into the current Revit project"/>
                    <Button x:Name="btn_presets" Content="&#x1F4E6; Presets"
                            Click="presets_clicked"
                            IsEnabled="False"
                            Padding="16,8" FontSize="13" FontWeight="SemiBold"
                            Margin="0,0,8,0"
                            ToolTip="Presets (3D) — coming soon">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Background" Value="#E67E22"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E67E22"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btn_export_and_place" Content="&#x1F4CC; Export &amp; Place"
                            Click="export_and_place_clicked"
                            Padding="16,8" FontSize="13" FontWeight="SemiBold"
                            Margin="0,0,8,0"
                            ToolTip="Export each selected block as .rfa and place every CAD instance at its exact world-space position">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                                <Setter Property="Background" Value="#2980B9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2980B9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btn_export" Content="Export Selected"
                            Style="{StaticResource SuccessButton}" Click="export_clicked"
                            Padding="20,8" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="6" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0"
                Padding="14,8">
            <StackPanel>

                <!-- Progress panel: bar + Pause + Stop (hidden when idle) -->
                <Grid x:Name="progress_panel" Visibility="Collapsed" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="52"/>
                    </Grid.ColumnDefinitions>

                    <ProgressBar x:Name="pb_export" Grid.Column="0"
                                 Height="8" Minimum="0" Maximum="100" Value="0"
                                 Foreground="#3498DB" Background="#DCE9F5"
                                 BorderThickness="0" VerticalAlignment="Center"/>

                    <!-- Pause / Resume -->
                    <Button x:Name="btn_pause_export" Grid.Column="2"
                            Content="⏸  Pause" Height="22" FontSize="10" FontFamily="Segoe UI"
                            Click="pause_resume_clicked" Cursor="Hand"
                            BorderThickness="1" BorderBrush="#BDC3C7"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#ECF0F1"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3" Padding="6,2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#D5DBDB"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#BDC3C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Stop -->
                    <Button x:Name="btn_stop_export" Grid.Column="4"
                            Content="■  Stop" Height="22" FontSize="10" FontFamily="Segoe UI"
                            Click="stop_export_clicked" Cursor="Hand"
                            BorderThickness="0" VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E74C3C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="3" Padding="6,2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C0392B"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#BDC3C7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Status text row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="status_text" Grid.Column="0" FontSize="11"
                               Foreground="#7F8C8D" Text="Ready"/>
                    <TextBlock x:Name="block_count_text" Grid.Column="1" FontSize="11"
                               Foreground="#BDC3C7" Text="0 blocks found"/>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Window>

