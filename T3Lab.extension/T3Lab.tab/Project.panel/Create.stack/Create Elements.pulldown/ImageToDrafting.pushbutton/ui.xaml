<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image To Drafting View - T3Lab" 
        Height="540" Width="460"
        MinWidth="400" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="White"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="8"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Window Control Button Style -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Close Button Style (Red on hover) -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E74C3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#BDC3C7"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D5DBDB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Textbox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="White" Height="64">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="T3Lab" FontSize="11" FontWeight="Bold"
                               Foreground="#3498DB" VerticalAlignment="Bottom" Margin="0,0,6,3"/>
                    <TextBlock Text="Image To Drafting" FontSize="18" FontWeight="Bold"
                               Foreground="#2C3E50"/>
                </StackPanel>
                <Separator Height="1" Background="#BDC3C7" Margin="0,2,0,2"/>
                <TextBlock Text="Convert images or clipboard screenshots to detail vector lines"
                           FontSize="10" Foreground="#7F8C8D" FontStyle="Italic"/>
            </StackPanel>

            <!-- Window Control Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,5,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="btn_minimize" Style="{StaticResource WindowControlButton}"
                        ToolTip="Minimize" Click="minimize_button_clicked">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>
                <Button x:Name="btn_maximize" Style="{StaticResource WindowControlButton}"
                        ToolTip="Maximize" Click="maximize_button_clicked">
                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82"/>
                </Button>
                <Button x:Name="btn_close" Style="{StaticResource CloseButton}"
                        ToolTip="Close" Click="close_button_clicked">
                    <TextBlock x:Name="close_text" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#005B82">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Header Separator -->
        <Border Grid.Row="1" Background="#ECF0F1"/>

        <!-- Main Content -->
        <Grid Grid.Row="2" Margin="16,16,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Drafting View Name Input -->
            <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,12">
                <TextBlock Text="Drafting View Name" FontWeight="SemiBold" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,6"/>
                <TextBox x:Name="ViewNameInput" Style="{StaticResource ModernTextBox}"
                         Text="Image Import"/>
            </StackPanel>

            <!-- Drag & Drop Area / Preview -->
            <Border Grid.Row="1" BorderBrush="#3498DB" BorderThickness="1.5" CornerRadius="6"
                    Background="#F8F9FA" AllowDrop="True" Drop="Border_Drop" Margin="0,0,0,16">
                <Grid>
                    <!-- Background instruction -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="0" Margin="20">
                        <TextBlock Text="📎" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="#BDC3C7"/>
                        <TextBlock Text="Paste Image (Ctrl+V) or Drag &amp; Drop Here"
                                   HorizontalAlignment="Center" FontWeight="Medium"
                                   Foreground="#7F8C8D" FontSize="13" TextAlignment="Center"/>
                        <TextBlock Text="Supports JPG, PNG, BMP"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"
                                   Foreground="#BDC3C7" FontSize="11" TextAlignment="Center"/>
                    </StackPanel>
                    <!-- Preview Image -->
                    <Image x:Name="ImagePreview" Stretch="Uniform" Panel.ZIndex="1" Margin="8"/>
                </Grid>
            </Border>

            <!-- Control Buttons -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="📂  Browse Image..." Height="36"
                        Style="{StaticResource SecondaryButton}" Click="Browse_Click"/>
                <Button Grid.Column="2" Content="✕  Clear Image" Height="36"
                        Style="{StaticResource SecondaryButton}" Click="Clear_Click"/>
            </Grid>

            <!-- Run Button -->
            <Button Grid.Row="3" x:Name="CreateBtn" Content="▶  Create Drafting View"
                    Height="42" Style="{StaticResource PrimaryButton}" Click="Create_Click"/>
        </Grid>
    </Grid>
</Window>
