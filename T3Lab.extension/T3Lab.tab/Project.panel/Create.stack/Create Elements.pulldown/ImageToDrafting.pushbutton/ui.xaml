<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image To Drafting View" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
            <Label Content="Drafting View Name:" FontWeight="Bold" Padding="0,0,0,5"/>
            <TextBox x:Name="ViewNameInput" Height="26" VerticalContentAlignment="Center" Padding="5,0"/>
        </StackPanel>
        
        <Border Grid.Row="1" BorderBrush="#cccccc" BorderThickness="2" Margin="0,5,0,15" Background="#f8f8f8" AllowDrop="True" Drop="Border_Drop">
            <Grid>
                <TextBlock Text="Paste (Ctrl+V) or Drop Image Here" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#888888" FontSize="14" Panel.ZIndex="0" TextWrapping="Wrap" TextAlignment="Center" Margin="20"/>
                <Image x:Name="ImagePreview" Stretch="Uniform" Panel.ZIndex="1" Margin="5"/>
            </Grid>
        </Border>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <Button Content="Browse Image..." Width="120" Height="30" Margin="0,0,10,0" Click="Browse_Click"/>
            <Button Content="Clear" Width="80" Height="30" Click="Clear_Click"/>
        </StackPanel>
        
        <Button x:Name="CreateBtn" Content="Create Drafting View" Grid.Row="3" Height="40" Click="Create_Click" FontWeight="Bold" Background="#007acc" Foreground="White" BorderThickness="0"/>
    </Grid>
</Window>
